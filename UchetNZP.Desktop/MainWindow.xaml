<Window x:Class="UchetNZP.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="UchetNZP Desktop"
        Width="1280"
        Height="720"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F3F4F6"
                BorderBrush="#D9DEE7"
                BorderThickness="1"
                CornerRadius="10"
                Padding="8"
                Margin="0,0,0,8">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="0,0,8,0">
                    <Button x:Name="BackButton" Width="32" Height="32" Margin="0,0,6,0" Click="BackButton_OnClick">←</Button>
                    <Button x:Name="ForwardButton" Width="32" Height="32" Margin="0,0,6,0" Click="ForwardButton_OnClick">→</Button>
                    <Button x:Name="RefreshButton" Width="32" Height="32" Click="RefreshButton_OnClick">↻</Button>
                </StackPanel>

                <TextBox x:Name="AddressBox"
                         Height="32"
                         VerticalContentAlignment="Center"
                         Padding="10,0"
                         Background="White"
                         BorderBrush="#D0D6E0"
                         BorderThickness="1"
                         KeyDown="AddressBox_OnKeyDown" />
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="10" ClipToBounds="True">
            <wv2:WebView2 x:Name="Browser" />
        </Border>
    </Grid>
</Window>
