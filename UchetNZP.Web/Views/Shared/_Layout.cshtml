@using Microsoft.Extensions.Options
@using System.Text.Json
@using UchetNZP.Web.Configuration
@inject IOptions<BackgroundBubblesOptions> BackgroundBubblesOptions
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Учёт НЗП</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-table@1.22.3/dist/bootstrap-table.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UchetNZP.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div id="backgroundBubblesRoot" class="background-bubbles" aria-hidden="true"></div>

    @{
        var currentController = (ViewContext.RouteData.Values["controller"] as string) ?? string.Empty;
        var currentAction = (ViewContext.RouteData.Values["action"] as string) ?? string.Empty;
        var pageTitle = ViewData["Title"]?.ToString() ?? "Рабочая область";
    }

    <div class="app-shell app-content-layer">
        <aside class="app-sidebar offcanvas-lg offcanvas-start" tabindex="-1" id="appSidebar" aria-labelledby="appSidebarTitle">

            <div class="offcanvas-body app-sidebar__body">
                <a class="app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="app-brand__mark">НЗП</span>
                    <span>
                        <strong>Учёт НЗП</strong>
                        <small>производственный контур</small>
                    </span>
                </a>

                <nav class="app-nav" aria-label="Основная навигация">
                    <div class="app-nav__section">
                        <div class="app-nav__title">Работа</div>
                        <a class="app-nav__link @(currentController == "Home" ? "active" : string.Empty)" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid-1x2" aria-hidden="true"></i>
                            <span>Главная</span>
                        </a>
                        <a class="app-nav__link @(currentController == "WipLaunches" && currentAction == "Index" ? "active" : string.Empty)" asp-area="" asp-controller="WipLaunches" asp-action="Index">
                            <i class="bi bi-diagram-3" aria-hidden="true"></i>
                            <span>Расчёт маршрута</span>
                        </a>
                        <a class="app-nav__link @(currentController == "WipReceipts" ? "active" : string.Empty)" asp-area="" asp-controller="WipReceipts" asp-action="Index">
                            <i class="bi bi-plus-square" aria-hidden="true"></i>
                            <span>Приход НЗП</span>
                        </a>
                        <a class="app-nav__link @(currentController == "WipTransfers" ? "active" : string.Empty)" asp-area="" asp-controller="WipTransfers" asp-action="Index">
                            <i class="bi bi-arrow-left-right" aria-hidden="true"></i>
                            <span>Переход партии</span>
                        </a>
                        <a class="app-nav__link @(currentController == "WipHistory" || (currentController == "WipLaunches" && currentAction == "History") ? "active" : string.Empty)" asp-area="" asp-controller="WipHistory" asp-action="Index">
                            <i class="bi bi-clock-history" aria-hidden="true"></i>
                            <span>История НЗП</span>
                        </a>
                        <a class="app-nav__link @(currentController == "WipLabels" ? "active" : string.Empty)" asp-area="" asp-controller="WipLabels" asp-action="Index">
                            <i class="bi bi-tags" aria-hidden="true"></i>
                            <span>Ярлыки НЗП</span>
                        </a>
                        <a class="app-nav__link @(currentController == "Warehouse" ? "active" : string.Empty)" asp-area="" asp-controller="Warehouse" asp-action="Index">
                            <i class="bi bi-box-seam" aria-hidden="true"></i>
                            <span>Склад СГДУ</span>
                        </a>
                    </div>

                    <div class="app-nav__section">
                        <div class="app-nav__title">Склад металла</div>
                        <a class="app-nav__link @(currentController == "MetalWarehouse" && currentAction == "Index" ? "active" : string.Empty)" asp-area="" asp-controller="MetalWarehouse" asp-action="Index">
                            <i class="bi bi-speedometer2" aria-hidden="true"></i>
                            <span>Обзор</span>
                        </a>
                        <a class="app-nav__link @(currentController == "MetalWarehouse" && currentAction == "Receipts" ? "active" : string.Empty)" asp-area="" asp-controller="MetalWarehouse" asp-action="Receipts">
                            <i class="bi bi-box-arrow-in-down" aria-hidden="true"></i>
                            <span>Приход металла</span>
                        </a>
                        <a class="app-nav__link @(currentController == "MetalWarehouse" && currentAction == "CreateReceipt" ? "active" : string.Empty)" asp-area="" asp-controller="MetalWarehouse" asp-action="CreateReceipt">
                            <i class="bi bi-plus-circle" aria-hidden="true"></i>
                            <span>Новый приход</span>
                        </a>
                        <a class="app-nav__link @(currentController == "MetalWarehouse" && currentAction == "Suppliers" ? "active" : string.Empty)" asp-area="" asp-controller="MetalWarehouse" asp-action="Suppliers">
                            <i class="bi bi-building" aria-hidden="true"></i>
                            <span>Поставщики</span>
                        </a>
                        <a class="app-nav__link @(currentController == "MetalWarehouse" && currentAction == "Stock" ? "active" : string.Empty)" asp-area="" asp-controller="MetalWarehouse" asp-action="Stock">
                            <i class="bi bi-layers" aria-hidden="true"></i>
                            <span>Остатки</span>
                        </a>
                        <a class="app-nav__link @(currentController == "MetalWarehouse" && currentAction == "Requirements" ? "active" : string.Empty)" asp-area="" asp-controller="MetalWarehouse" asp-action="Requirements">
                            <i class="bi bi-clipboard-check" aria-hidden="true"></i>
                            <span>Требования</span>
                        </a>
                        <a class="app-nav__link @(currentController == "MetalWarehouse" && currentAction == "Issues" ? "active" : string.Empty)" asp-area="" asp-controller="MetalWarehouse" asp-action="Issues">
                            <i class="bi bi-box-arrow-up" aria-hidden="true"></i>
                            <span>Выдачи</span>
                        </a>
                        <a class="app-nav__link @(currentController == "MetalWarehouse" && currentAction == "Movements" ? "active" : string.Empty)" asp-area="" asp-controller="MetalWarehouse" asp-action="Movements">
                            <i class="bi bi-activity" aria-hidden="true"></i>
                            <span>Движения</span>
                        </a>
                        <a class="app-nav__link @(currentController == "MetalWarehouse" && currentAction == "CuttingReports" ? "active" : string.Empty)" asp-area="" asp-controller="MetalWarehouse" asp-action="CuttingReports">
                            <i class="bi bi-scissors" aria-hidden="true"></i>
                            <span>Факт раскроя</span>
                        </a>
                        <a class="app-nav__link @(currentController == "MetalWarehouse" && currentAction == "CuttingMaps" ? "active" : string.Empty)" asp-area="" asp-controller="MetalWarehouse" asp-action="CuttingMaps">
                            <i class="bi bi-map" aria-hidden="true"></i>
                            <span>Карты раскроя</span>
                        </a>
                    </div>

                    <div class="app-nav__section">
                        <div class="app-nav__title">Отчеты и справочники</div>
                        <a class="app-nav__link @(currentController == "ReceiptReport" ? "active" : string.Empty)" asp-area="" asp-controller="Reports" asp-action="ReceiptReport">
                            <i class="bi bi-file-earmark-bar-graph" aria-hidden="true"></i>
                            <span>Отчет по запускам</span>
                        </a>
                        <a class="app-nav__link @(currentController == "Reports" && currentAction == "TransferPeriodReport" ? "active" : string.Empty)" asp-area="" asp-controller="Reports" asp-action="TransferPeriodReport">
                            <i class="bi bi-file-earmark-bar-graph" aria-hidden="true"></i>
                            <span>Отчёт по переходам</span>
                        </a>
                        <a class="app-nav__link @(currentController == "Reports" && currentAction == "ScrapReport" ? "active" : string.Empty)" asp-area="" asp-controller="Reports" asp-action="ScrapReport">
                            <i class="bi bi-file-earmark-bar-graph" aria-hidden="true"></i>
                            <span>Отчёт по браку</span>
                        </a>
                        <a class="app-nav__link @(currentController == "Reports" && currentAction == "WipBatchReport" ? "active" : string.Empty)" asp-area="" asp-controller="Reports" asp-action="WipBatchReport">
                            <i class="bi bi-file-earmark-bar-graph" aria-hidden="true"></i>
                            <span>Остатки на партиях</span>
                        </a>
                        <a class="app-nav__link @(currentController == "Reports" && currentAction == "LabelMovementReport" ? "active" : string.Empty)" asp-area="" asp-controller="Reports" asp-action="LabelMovementReport">
                            <i class="bi bi-file-earmark-bar-graph" aria-hidden="true"></i>
                            <span>Движение ярлыка</span>
                        </a>
                       
                        <a class="app-nav__link @(currentController == "Routes" && currentAction == "Index" ? "active" : string.Empty)" asp-area="" asp-controller="Routes" asp-action="Index">
                            <i class="bi bi-signpost-split" aria-hidden="true"></i>
                            <span>Маршруты</span>
                        </a>
                        <a class="app-nav__link @(currentController == "Routes" && currentAction == "Import" ? "active" : string.Empty)" asp-area="" asp-controller="Routes" asp-action="Import">
                            <i class="bi bi-upload" aria-hidden="true"></i>
                            <span>Импорт маршрутов</span>
                        </a>
                        <a class="app-nav__link @(currentController == "AdminMetalMaterials" ? "active" : string.Empty)" asp-area="" asp-controller="AdminMetalMaterials" asp-action="Index">
                            <i class="bi bi-database-gear" aria-hidden="true"></i>
                            <span>Материалы</span>
                        </a>
                        <a class="app-nav__link @(currentController == "AdminWip" ? "active" : string.Empty)" asp-area="" asp-controller="AdminWip" asp-action="Index">
                            <i class="bi bi-sliders" aria-hidden="true"></i>
                            <span>Админ НЗП</span>
                        </a>
                        <a class="app-nav__link @(currentController == "Admin" ? "active" : string.Empty)" asp-area="" asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-table" aria-hidden="true"></i>
                            <span>Справочники</span>
                        </a>
                    </div>
                </nav>
            </div>
        </aside>

        <div class="app-main">
            <header class="app-topbar">
                <div class="app-topbar__left">
                    <button class="btn btn-icon app-menu-button d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#appSidebar" aria-controls="appSidebar" aria-label="Открыть навигацию">
                        <i class="bi bi-list" aria-hidden="true"></i>
                    </button>
                    <div class="app-topbar__title">
                        <span>Рабочая область</span>
                        <strong>@pageTitle</strong>
                    </div>
                </div>

                <form id="navbarLabelSearchForm"
                      class="app-label-search"
                      method="get"
                      asp-area=""
                      asp-controller="Reports"
                      asp-action="LabelMovementReport"
                      autocomplete="off"
                      novalidate>
                    <label for="navbarLabelSearchInput" class="form-label">Ярлык</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="bi bi-upc-scan" aria-hidden="true"></i></span>
                        <input id="navbarLabelSearchInput"
                               class="form-control"
                               type="text"
                               name="label"
                               list="navbarLabelSearchOptions"
                               placeholder="12345 или 12345/1"
                               inputmode="numeric"
                               aria-describedby="navbarLabelSearchError"
                               maxlength="11" />
                        <datalist id="navbarLabelSearchOptions"></datalist>
                        <button type="submit" class="btn btn-primary">Найти</button>
                    </div>
                    <div id="navbarLabelSearchError" class="invalid-feedback d-block d-none"></div>
                </form>
            </header>

            <main role="main" class="app-page">
                <div class="app-page__inner">
                    @RenderBody()
                </div>
            </main>

            <div class="toast-container position-fixed top-0 end-0 p-3" id="appToastContainer" aria-live="polite" aria-atomic="true"></div>

            <div class="modal fade" id="appConfirmModal" tabindex="-1" aria-labelledby="appConfirmModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="appConfirmModalLabel">Подтверждение</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                        </div>
                        <div class="modal-body">
                            <p class="mb-2" id="appConfirmModalMessage">Подтвердите действие.</p>
                            <div class="fw-semibold" id="appConfirmModalEntity"></div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                            <button type="button" class="btn btn-danger" id="appConfirmModalSubmit">Удалить</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-table@1.22.3/dist/bootstrap-table.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-table@1.22.3/dist/locale/bootstrap-table-ru-RU.min.js"></script>
    <script src="~/js/common-ui.js" asp-append-version="true"></script>
    <script>
        window.backgroundBubblesConfig = @Html.Raw(JsonSerializer.Serialize(new
        {
            enabled = BackgroundBubblesOptions.Value.Enabled
        }));
    </script>
    <script src="~/js/background-bubbles.js" asp-append-version="true"></script>
    <script>
        (function () {
            const form = document.getElementById("navbarLabelSearchForm");
            const input = document.getElementById("navbarLabelSearchInput");
            const error = document.getElementById("navbarLabelSearchError");
            const suggestions = document.getElementById("navbarLabelSearchOptions");
            const labelNumberPattern = /^\d{1,5}(?:\/\d{1,5})?$/;
            let suggestTimer = null;

            function normalizeLabelNumber(rawValue) {
                if (typeof rawValue !== "string") {
                    return "";
                }

                const value = rawValue.trim();
                return labelNumberPattern.test(value) ? value : "";
            }

            function showError(message) {
                if (!error || !input) {
                    return;
                }

                error.textContent = message;
                error.classList.remove("d-none");
                input.classList.add("is-invalid");
            }

            function clearError() {
                if (!error || !input) {
                    return;
                }

                error.textContent = "";
                error.classList.add("d-none");
                input.classList.remove("is-invalid");
            }


            function renderSuggestions(items) {
                if (!suggestions) {
                    return;
                }

                suggestions.innerHTML = "";
                items.forEach(item => {
                    if (!item || typeof item.number !== "string" || !item.number.trim()) {
                        return;
                    }

                    const option = document.createElement("option");
                    option.value = item.number.trim();
                    suggestions.appendChild(option);
                });
            }

            async function loadSuggestions(rawValue) {
                const term = typeof rawValue === "string" ? rawValue.trim() : "";
                if (term.length < 2) {
                    renderSuggestions([]);
                    return;
                }

                try {
                    const response = await fetch(`/reports/label-movement/suggest?search=${encodeURIComponent(term)}`);
                    if (!response.ok) {
                        renderSuggestions([]);
                        return;
                    }

                    const data = await response.json();
                    renderSuggestions(Array.isArray(data) ? data : []);
                }
                catch (errorFetch) {
                    console.error(errorFetch);
                    renderSuggestions([]);
                }
            }

            form?.addEventListener("submit", event => {
                const normalized = normalizeLabelNumber(input?.value ?? "");
                if (!normalized) {
                    event.preventDefault();
                    showError("Введите номер ярлыка в формате 12345 или 12345/1.");
                    return;
                }

                if (input) {
                    input.value = normalized;
                }

                clearError();
            });

            input?.addEventListener("input", () => {
                clearError();

                if (suggestTimer) {
                    window.clearTimeout(suggestTimer);
                }

                suggestTimer = window.setTimeout(() => {
                    void loadSuggestions(input.value);
                }, 200);
            });
        })();
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
