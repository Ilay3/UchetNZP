@using Microsoft.Extensions.Options
@using System.Text.Json
@using UchetNZP.Web.Configuration
@inject IOptions<BackgroundBubblesOptions> BackgroundBubblesOptions
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Учёт НЗП</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-table@1.22.3/dist/bootstrap-table.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UchetNZP.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div id="backgroundBubblesRoot" class="background-bubbles" aria-hidden="true"></div>

    <div class="app-content-layer">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light app-surface border-bottom shadow-sm mb-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Учёт НЗП</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Переключить навигацию">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between align-items-lg-center gap-3">
                    <ul class="navbar-nav flex-grow-1 gap-3">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-uppercase small fw-semibold" href="#" id="operationsMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Расчёт до конца маршрута
                            </a>

                            <ul class="dropdown-menu shadow" aria-labelledby="operationsMenu">
                                
                                <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="WipLaunches" asp-action="Index">Расчёт до конца маршрута</a>
                                </li>

                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="WipLaunches" asp-action="History">История расчётов</a>
                                </li>

                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-uppercase small fw-semibold" href="#" id="operationsMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Операции
                            </a>

                            <ul class="dropdown-menu shadow" aria-labelledby="operationsMenu">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="WipReceipts" asp-action="Index">Запуск партии</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="WipTransfers" asp-action="Index">Переход партии</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Warehouse" asp-action="Index">Склад (Не работает)</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="WipHistory" asp-action="Index">История</a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-uppercase small fw-semibold" href="#" id="metalWarehouseMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Склад металла
                            </a>
                            <ul class="dropdown-menu shadow" aria-labelledby="metalWarehouseMenu">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="MetalWarehouse" asp-action="Index">Стартовая страница</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="MetalWarehouse" asp-action="Receipts">Приход металла</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="MetalWarehouse" asp-action="Stock">Остатки металла</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="MetalWarehouse" asp-action="Requirements">Требования производства</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="MetalWarehouse" asp-action="Issues">Выдачи по требованиям</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="MetalWarehouse" asp-action="Movements">История движений</a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-uppercase small fw-semibold" href="#" id="reportsMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Отчёты
                            </a>
                            <ul class="dropdown-menu shadow" aria-labelledby="reportsMenu">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Reports" asp-action="ReceiptReport">Отчёт по запуску</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Reports" asp-action="TransferPeriodReport">Отчёт по переходам</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Reports" asp-action="ScrapReport">Отчёт по браку</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Reports" asp-action="WipBatchReport">Остатки на партиях</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Reports" asp-action="LabelMovementReport">Движение ярлыка</a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-uppercase small fw-semibold" href="#" id="adminMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Технологические процессы
                            </a>
                            <ul class="dropdown-menu shadow" aria-labelledby="adminMenu">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Routes" asp-action="Index">Маршруты деталей</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Routes" asp-action="Import">Маршруты (импорт)</a>
                                </li>
                                
                            </ul>
                        </li>
                    </ul>

                    <form id="navbarLabelSearchForm"
                          class="d-flex flex-column flex-lg-row gap-2 my-3 my-lg-0"
                          method="get"
                          asp-area=""
                          asp-controller="Reports"
                          asp-action="LabelMovementReport"
                          autocomplete="off"
                          novalidate>
                        <label for="navbarLabelSearchInput" class="form-label mb-0 small text-muted">Ярлык</label>
                        <div class="input-group input-group-sm">
                            <input id="navbarLabelSearchInput"
                                   class="form-control"
                                   type="text"
                                   name="label"
                                   list="navbarLabelSearchOptions"
                                   placeholder="12345 или 12345/1"
                                   inputmode="numeric"
                                   aria-describedby="navbarLabelSearchError"
                                   maxlength="11" />
                            <datalist id="navbarLabelSearchOptions"></datalist>
                            <button type="submit" class="btn btn-outline-primary">Найти</button>
                        </div>
                        <div id="navbarLabelSearchError" class="invalid-feedback d-block d-none"></div>
                    </form>
                </div>
            </div>
        </nav>
    </header>
    <div class="container pb-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <div class="toast-container position-fixed top-0 end-0 p-3" id="appToastContainer" aria-live="polite" aria-atomic="true"></div>

    <div class="modal fade" id="appConfirmModal" tabindex="-1" aria-labelledby="appConfirmModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="appConfirmModalLabel">Подтверждение</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2" id="appConfirmModalMessage">Подтвердите действие.</p>
                    <div class="fw-semibold" id="appConfirmModalEntity"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-danger" id="appConfirmModalSubmit">Удалить</button>
                </div>
            </div>
        </div>
    </div>



    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-table@1.22.3/dist/bootstrap-table.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-table@1.22.3/dist/locale/bootstrap-table-ru-RU.min.js"></script>
    <script src="~/js/common-ui.js" asp-append-version="true"></script>
    <script>
        window.backgroundBubblesConfig = @Html.Raw(JsonSerializer.Serialize(new
        {
            enabled = BackgroundBubblesOptions.Value.Enabled
        }));
    </script>
    <script src="~/js/background-bubbles.js" asp-append-version="true"></script>
    <script>
        (function () {
            const form = document.getElementById("navbarLabelSearchForm");
            const input = document.getElementById("navbarLabelSearchInput");
            const error = document.getElementById("navbarLabelSearchError");
            const suggestions = document.getElementById("navbarLabelSearchOptions");
            const labelNumberPattern = /^\d{1,5}(?:\/\d{1,5})?$/;
            let suggestTimer = null;

            function normalizeLabelNumber(rawValue) {
                if (typeof rawValue !== "string") {
                    return "";
                }

                const value = rawValue.trim();
                return labelNumberPattern.test(value) ? value : "";
            }

            function showError(message) {
                if (!error || !input) {
                    return;
                }

                error.textContent = message;
                error.classList.remove("d-none");
                input.classList.add("is-invalid");
            }

            function clearError() {
                if (!error || !input) {
                    return;
                }

                error.textContent = "";
                error.classList.add("d-none");
                input.classList.remove("is-invalid");
            }


            function renderSuggestions(items) {
                if (!suggestions) {
                    return;
                }

                suggestions.innerHTML = "";
                items.forEach(item => {
                    if (!item || typeof item.number !== "string" || !item.number.trim()) {
                        return;
                    }

                    const option = document.createElement("option");
                    option.value = item.number.trim();
                    suggestions.appendChild(option);
                });
            }

            async function loadSuggestions(rawValue) {
                const term = typeof rawValue === "string" ? rawValue.trim() : "";
                if (term.length < 2) {
                    renderSuggestions([]);
                    return;
                }

                try {
                    const response = await fetch(`/reports/label-movement/suggest?search=${encodeURIComponent(term)}`);
                    if (!response.ok) {
                        renderSuggestions([]);
                        return;
                    }

                    const data = await response.json();
                    renderSuggestions(Array.isArray(data) ? data : []);
                }
                catch (errorFetch) {
                    console.error(errorFetch);
                    renderSuggestions([]);
                }
            }

            form?.addEventListener("submit", event => {
                const normalized = normalizeLabelNumber(input?.value ?? "");
                if (!normalized) {
                    event.preventDefault();
                    showError("Введите номер ярлыка в формате 12345 или 12345/1.");
                    return;
                }

                if (input) {
                    input.value = normalized;
                }

                clearError();
            });

            input?.addEventListener("input", () => {
                clearError();

                if (suggestTimer) {
                    window.clearTimeout(suggestTimer);
                }

                suggestTimer = window.setTimeout(() => {
                    void loadSuggestions(input.value);
                }, 200);
            });
        })();
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
