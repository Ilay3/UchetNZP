@using System
@using UchetNZP.Shared
@model UchetNZP.Web.Models.WipBatchReportViewModel
@{
    ViewData["Title"] = "Остатки партий НЗП";
}

<div class="page-header mb-4">
    <h1 class="display-5 fw-semibold">Остатки партий НЗП</h1>
    <p class="lead mb-0">Просматривайте текущие остатки по деталям, ярлыкам и операциям (без учёта склада).</p>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end" autocomplete="off">
            <div class="col-md-3">
                <label class="form-label" for="batchFromInput">Период с</label>
                <input id="batchFromInput" class="form-control form-control-lg" type="date" name="from" value='@Model.Filter.From.ToString("yyyy-MM-dd")' />
            </div>
            <div class="col-md-3">
                <label class="form-label" for="batchToInput">по</label>
                <input id="batchToInput" class="form-control form-control-lg" type="date" name="to" value='@Model.Filter.To.ToString("yyyy-MM-dd")' />
            </div>
            <div class="col-md-3">
                <label class="form-label" for="batchPartInput">Деталь</label>
                <input id="batchPartInput" class="form-control form-control-lg" type="text" name="part" value='@Model.Filter.Part' placeholder="Наименование или обозначение детали" />
            </div>
            <div class="col-md-3">
                <label class="form-label" for="batchSectionInput">Вид работ</label>
                <input id="batchSectionInput" class="form-control form-control-lg" type="text" name="section" value='@Model.Filter.Section' placeholder="Наименование или код вида работ" />
            </div>
            <div class="col-md-3">
                <label class="form-label" for="batchOpInput">№ операции</label>
                <input id="batchOpInput" class="form-control form-control-lg" type="text" name="opNumber" value='@Model.Filter.OpNumber' pattern="@OperationNumber.AllowedPattern" inputmode="text" />
            </div>
            <div class="col-12 col-md-6 d-flex flex-wrap gap-3">
                <button type="submit" class="btn btn-primary btn-lg flex-grow-1">Применить</button>
                <a class="btn btn-secondary btn-lg flex-grow-1"
                   asp-action="WipBatchReport"
                   asp-route-from='@DateTime.Now.AddDays(-29).ToString("yyyy-MM-dd")'
                   asp-route-to='@DateTime.Now.ToString("yyyy-MM-dd")'>Сбросить</a>
            </div>
        </form>
    </div>
</div>

@if (Model.HasData)
{
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light fw-semibold">
            <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                <div class="d-flex flex-column flex-md-row gap-3">
                    <span>Найдено записей: @Model.Items.Count</span>
                    <span>Суммарный остаток: @Model.TotalQuantity.ToString("0.###")</span>
                </div>
                <div class="d-flex gap-2">
                    <form method="post"
                          asp-action="WipBatchInventoryDocumentCreate"
                          asp-route-from='@Model.Filter.From.ToString("yyyy-MM-dd")'
                          asp-route-to='@Model.Filter.To.ToString("yyyy-MM-dd")'
                          asp-route-part='@Model.Filter.Part'
                          asp-route-section='@Model.Filter.Section'
                          asp-route-opNumber='@Model.Filter.OpNumber'>
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success">Сформировать акт инвентаризации</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
                <div class="text-muted small">Таблица разбита на страницы, чтобы список остатков было проще просматривать.</div>
                <div id="batchItemsPaginationSummary" class="small text-muted"></div>
            </div>
            <div class="table-responsive">
                <table class="table table-striped align-middle" aria-describedby="batchReportCaption">
                    <caption id="batchReportCaption" class="visually-hidden">Отчёт по остаткам партий НЗП</caption>
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Деталь</th>
                            <th scope="col">Вид работ</th>
                            <th scope="col">Операция</th>
                            <th scope="col">Ярлыки</th>
                            <th scope="col">Остаток</th>
                            <th scope="col">Дата партии</th>
                        </tr>
                    </thead>
                    <tbody id="batchItemsTableBody">
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.PartName</div>
                                    @if (!string.IsNullOrWhiteSpace(item.PartCode) && !string.Equals(item.PartCode?.Trim(), item.PartName?.Trim(), StringComparison.OrdinalIgnoreCase))
                                    {
                                        <div class="text-muted small">@item.PartCode</div>
                                    }
                                </td>
                                <td>@item.SectionName</td>
                                <td>@item.OpNumber</td>
                                <td>@(string.IsNullOrWhiteSpace(item.LabelNumbers) ? "—" : item.LabelNumbers)</td>
                                <td>@item.Quantity.ToString("0.###")</td>
                                <td>@item.BatchDate.ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <nav id="batchItemsPagination" aria-label="Постраничная навигация по остаткам партий"></nav>
        </div>
    </div>
}
else
{
    <div class="alert alert-light border shadow-sm">
        <div class="fw-semibold mb-1">По выбранным условиям данные не найдены.</div>
        <p class="mb-0">Измените период или параметры фильтра и попробуйте снова.</p>
    </div>
}

<div class="d-flex justify-content-end mt-4">
    <a class="btn btn-link" asp-controller="Home" asp-action="Index">← Вернуться на главную</a>
</div>


<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Список сформированных документов</div>
    <div class="card-body">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
            <div class="text-muted small">Документы показаны частями, чтобы страница оставалась компактной.</div>
            <div id="batchDocumentsPaginationSummary" class="small text-muted"></div>
        </div>
        @if (Model.Documents.Count == 0)
        {
            <div class="text-muted">Документы ещё не формировались.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">ID</th>
                            <th scope="col">Инв. номер</th>
                            <th scope="col">Дата формирования</th>
                            <th scope="col">Строк</th>
                            <th scope="col">Итого</th>
                            <th scope="col"></th>
                        </tr>
                    </thead>
                    <tbody id="batchDocumentsTableBody">
                        @foreach (var doc in Model.Documents)
                        {
                            <tr>
                                <td class="small text-break">@doc.Id</td>
                                <td>@doc.InventoryNumber.ToString("00")/инв</td>
                                <td>@doc.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@doc.RowCount</td>
                                <td>@doc.TotalQuantity.ToString("0.###")</td>
                                <td>
                                    <a class="btn btn-sm btn-outline-primary"
                                       asp-action="WipBatchInventoryDocumentDownload"
                                       asp-route-id='@doc.Id'>Скачать</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <nav id="batchDocumentsPagination" aria-label="Постраничная навигация по сформированным документам"></nav>
        }
    </div>
</div>

<script>
    (function () {
        function setupPagination(tableBodyId, pagerId, summaryId, pageSize) {
            const tableBody = document.getElementById(tableBodyId);
            const pager = document.getElementById(pagerId);
            const summary = document.getElementById(summaryId);
            if (!tableBody || !pager) {
                return;
            }

            const rows = Array.from(tableBody.querySelectorAll("tr"));
            const totalRows = rows.length;
            if (totalRows <= pageSize) {
                if (summary) {
                    summary.textContent = totalRows > 0
                        ? `Показаны все записи: ${totalRows}`
                        : "";
                }
                pager.innerHTML = "";
                return;
            }

            const totalPages = Math.ceil(totalRows / pageSize);
            let currentPage = 1;

            function render() {
                const start = (currentPage - 1) * pageSize;
                const end = start + pageSize;

                rows.forEach((row, index) => {
                    row.style.display = index >= start && index < end ? "" : "none";
                });

                if (summary) {
                    summary.textContent = `Показано ${Math.min(end, totalRows)} из ${totalRows}`;
                }

                const prevDisabled = currentPage === 1 ? " disabled" : "";
                const nextDisabled = currentPage === totalPages ? " disabled" : "";
                pager.innerHTML = `
                    <ul class="pagination pagination-sm flex-wrap mb-0">
                        <li class="page-item${prevDisabled}">
                            <button type="button" class="page-link" data-page="${currentPage - 1}">Назад</button>
                        </li>
                        <li class="page-item disabled"><span class="page-link">${currentPage} / ${totalPages}</span></li>
                        <li class="page-item${nextDisabled}">
                            <button type="button" class="page-link" data-page="${currentPage + 1}">Вперёд</button>
                        </li>
                    </ul>`;
            }

            pager.addEventListener("click", function (event) {
                const target = event.target;
                if (!(target instanceof HTMLButtonElement)) {
                    return;
                }

                const page = Number(target.dataset.page);
                if (!Number.isFinite(page) || page < 1 || page > totalPages) {
                    return;
                }

                currentPage = page;
                render();
            });

            render();
        }

        setupPagination("batchItemsTableBody", "batchItemsPagination", "batchItemsPaginationSummary", 20);
        setupPagination("batchDocumentsTableBody", "batchDocumentsPagination", "batchDocumentsPaginationSummary", 10);
    })();
</script>
