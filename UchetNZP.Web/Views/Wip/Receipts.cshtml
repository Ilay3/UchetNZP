@{
    ViewData["Title"] = "Запуск партии НЗП";
}

<div class="page-header mb-4">
    <h1 class="display-5 fw-semibold">Запуск партии НЗП</h1>
    <p class="lead">Заполните поля по порядку: деталь, операция, материал, ярлык и количество.</p>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Шаг 1. Параметры запуска</div>
    <div class="card-body">
        <form id="receiptForm" class="row g-4" autocomplete="off">
            <div class="col-lg-4">
                <label class="form-label" for="receiptPartInput">Деталь</label>
                <input id="receiptPartInput" class="form-control form-control-lg" type="text" list="receiptPartOptions" placeholder="Начните вводить деталь" autocomplete="off" />
                <datalist id="receiptPartOptions"></datalist>
                <input type="hidden" id="receiptPartId" />
                <div class="form-text">Ищите по наименованию или обозначению.</div>
            </div>
            <div class="col-lg-4">
                <label class="form-label" for="receiptLabelSearchInput">Ярлык детали</label>
                <input id="receiptLabelSearchInput" class="form-control form-control-lg" type="text" inputmode="numeric" placeholder="Введите номер ярлыка вручную (например, 12345 или 12345/1)" autocomplete="off" aria-describedby="receiptLabelHelp" />
                <input type="hidden" id="receiptLabelId" />
                <div class="form-text" id="receiptLabelHelp">Ярлык выбирается только вручную. Автоматический подбор отключён для упрощения работы.</div>
                <div id="receiptLabelMessage" class="alert alert-warning d-none mt-3" role="alert"></div>
            </div>
            <div class="col-lg-4">
                <label class="form-label" for="receiptDateInput">Дата</label>
                <input id="receiptDateInput" class="form-control form-control-lg" type="date" />
                <div class="form-text">Дата прихода устанавливается автоматически на сегодня и может быть изменена.</div>
            </div>
            <div class="col-lg-4">
                <label class="form-label" for="receiptQuantityInput">Количество деталей</label>
                <input id="receiptQuantityInput" class="form-control form-control-lg" type="number" min="1" step="1" />
                <div class="form-text">Количество должно быть не меньше 1.</div>
            </div>
            <div class="col-lg-4">
                <label class="form-label" for="receiptCommentInput">Комментарий</label>
                <input id="receiptCommentInput" class="form-control form-control-lg" type="text" maxlength="256" />
                <div class="form-text">Добавьте пояснение, если необходимо.</div>
            </div>
            <div class="col-lg-4 d-flex align-items-end">
                <div>
                    <div class="fw-semibold text-uppercase small text-muted">Текущий остаток по операции</div>
                    <div class="display-6" id="receiptBalanceLabel">0 шт</div>
                    <div class="form-text">Остаток обновляется при выборе операции.</div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Материал заготовки</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-xl-5">
                <label class="form-label" for="receiptMaterialSelect">Материал</label>
                <select id="receiptMaterialSelect" class="form-select form-select-lg">
                    <option value="">Выберите материал</option>
                </select>
                <div class="form-text">Список берётся из активных материалов склада металла.</div>
            </div>
            <div class="col-sm-6 col-xl-2">
                <label class="form-label" for="receiptMaterialUnitInput">Ед. изм.</label>
                <input id="receiptMaterialUnitInput" type="text" class="form-control form-control-lg" value="—" readonly />
            </div>
            <div class="col-sm-6 col-xl-2">
                <div class="small text-muted text-uppercase">Доступно на складе</div>
                <div class="fs-5 fw-semibold" id="receiptMaterialAvailableLabel">—</div>
            </div>
            <div class="col-sm-6 col-xl-1">
                <div class="small text-muted text-uppercase">Количество единиц</div>
                <div class="fs-5 fw-semibold" id="receiptMaterialUnitsCountLabel">0</div>
            </div>
            <div class="col-sm-6 col-xl-1">
                <div class="small text-muted text-uppercase">Суммарный размер</div>
                <div class="fs-5 fw-semibold" id="receiptMaterialTotalSizeLabel">0</div>
            </div>
            <div class="col-sm-6 col-xl-1">
                <div class="small text-muted text-uppercase">Суммарный вес, кг</div>
                <div class="fs-5 fw-semibold" id="receiptMaterialTotalWeightLabel">0</div>
            </div>
        </div>
        <div id="receiptMaterialEmptyState" class="alert alert-light border mt-3 mb-0">
            <div class="fw-semibold">Материал не выбран</div>
            <div class="text-muted">Выберите материал, чтобы увидеть сводку склада и доступные единицы металла.</div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Доступные единицы металла</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle" id="receiptMaterialUnitsTable">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Код</th>
                        <th scope="col">Размер</th>
                        <th scope="col">Ед. изм.</th>
                        <th scope="col">Вес, кг</th>
                        <th scope="col">Дата прихода</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="5" class="text-center text-muted">Выберите материал, чтобы увидеть доступные единицы.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold d-flex justify-content-between align-items-center">
        <span>Шаг 2. Выберите операцию детали</span>
        <div class="small text-muted">Выберите одну операцию из списка ниже.</div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle" id="receiptOperationsTable" aria-describedby="receiptOperationsCaption">
                <caption id="receiptOperationsCaption" class="visually-hidden">Список операций выбранной детали</caption>
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="text-center">Выбор</th>
                        <th scope="col">№ операции</th>
                        <th scope="col">Наименование</th>
                        <th scope="col">Норматив, н/ч</th>
                        <th scope="col">Вид работ</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="5" class="text-center text-muted">Выберите деталь, чтобы увидеть операции.</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="d-flex flex-column flex-md-row gap-3 mt-3">
            <button type="button" class="btn btn-primary btn-lg" id="receiptAddButton">
                Добавить в корзину (Enter)
            </button>
            <button type="button" class="btn btn-outline-primary btn-lg" id="receiptBulkAddButton">
                Множественное добавление ярлыков
            </button>
            <button type="button" class="btn btn-secondary btn-lg" id="receiptResetButton">
                Очистить форму (Esc)
            </button>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-5">
    <div class="card-header bg-light fw-semibold d-flex justify-content-between align-items-center">
        <span>Корзина приходов</span>
        <button type="button" class="btn btn-success btn-lg" id="receiptSaveButton">
            Сохранить все приходы (Ctrl+S)
        </button>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped align-middle" id="receiptCartTable" aria-describedby="receiptCartCaption">
                <caption id="receiptCartCaption" class="visually-hidden">Приходы, подготовленные к сохранению</caption>
                <thead class="table-light">
                    <tr>
                        <th scope="col">Дата</th>
                        <th scope="col">Вид работ</th>
                        <th scope="col">Деталь</th>
                        <th scope="col">Операция</th>
                        <th scope="col">Материал</th>
                        <th scope="col">Ярлык</th>
                        <th scope="col">Было</th>
                        <th scope="col">Пришло</th>
                        <th scope="col">Станет</th>
                        <th scope="col">Комментарий</th>
                        <th scope="col" class="text-center">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="11" class="text-center text-muted">Добавьте операции в корзину для сохранения.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-5">
    <div class="card-header bg-light fw-semibold d-flex justify-content-between align-items-center">
        <span>Последние сохранённые приходы</span>
        <div class="small text-muted">Вы можете отменить сохранённые записи при необходимости.</div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered align-middle" id="receiptHistoryTable" aria-describedby="receiptHistoryCaption">
                <caption id="receiptHistoryCaption" class="visually-hidden">Список последних сохранённых приходов</caption>
                <thead class="table-light">
                    <tr>
                        <th scope="col">Дата</th>
                        <th scope="col">Вид работ</th>
                        <th scope="col">Деталь</th>
                        <th scope="col">Операция</th>
                        <th scope="col">Материал</th>
                        <th scope="col">Ярлык</th>
                        <th scope="col">Пришло</th>
                        <th scope="col">Остаток после</th>
                        <th scope="col" class="text-center">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="9" class="text-center text-muted">Сохранённые приходы появятся здесь.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="receiptBulkModal" tabindex="-1" aria-labelledby="receiptBulkModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h4" id="receiptBulkModalTitle">Множественное добавление приходов</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
            </div>
            <div class="modal-body">
                <label class="form-label" for="receiptBulkLabelsInput">Номера ярлыков (по одному в строке, через запятую или пробел)</label>
                <textarea id="receiptBulkLabelsInput" class="form-control" rows="7" placeholder="101\n102\n103"></textarea>
                <div class="form-text">Для каждого ярлыка будет создан отдельный приход с параметрами из текущей формы.</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-primary" id="receiptBulkConfirmButton">Добавить в корзину</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="receiptSummaryModal" tabindex="-1" aria-labelledby="receiptSummaryTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h4" id="receiptSummaryTitle">Сводка по сохранённым приходам</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3" id="receiptSummaryIntro"></p>
                <div class="table-responsive">
                    <table class="table table-bordered align-middle" id="receiptSummaryTable">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Деталь</th>
                                <th scope="col">Операция</th>
                                <th scope="col">Ярлык</th>
                                <th scope="col">Было</th>
                                <th scope="col">Пришло</th>
                                <th scope="col">Станет</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary btn-lg" data-bs-dismiss="modal">Понятно</button>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="~/js/receipts.js" asp-append-version="true"></script>
}
