@using UchetNZP.Shared
@model UchetNZP.Web.Models.WipQualityIndexViewModel
@{
    ViewData["Title"] = "ОТК";
}

<div class="page-header mb-4">
    <h1 class="display-5 fw-semibold">ОТК</h1>
    <p class="lead mb-0">Очередь деталей на контрольной операции и задел под дальнейшую фиксацию исправимого и неисправимого брака.</p>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold d-flex justify-content-between align-items-center">
        <span>Детали на стадии ОТК</span>
        <span class="small text-muted">@Model.Items.Count позиций</span>
    </div>
    <div class="card-body">
        @if (!Model.HasItems)
        {
            <div class="alert alert-light border mb-0">Деталей на стадии ОТК сейчас нет.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle" data-app-pagination="true" data-app-page-size="25">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Деталь</th>
                            <th scope="col">Операция ОТК</th>
                            <th scope="col">Количество</th>
                            <th scope="col">Ярлыки</th>
                            <th scope="col">Будущая логика брака</th>
                            <th scope="col">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@NameWithCodeFormatter.getNameWithCode(item.PartName, item.PartCode)</div>
                                    <div class="small text-muted">@item.SectionName</div>
                                </td>
                                <td>
                                    <div class="fw-semibold">@item.OpNumber</div>
                                    <div class="small text-muted">@item.OperationName</div>
                                </td>
                                <td>@item.Quantity.ToString("0.###") шт</td>
                                <td>
                                    @if (item.Labels.Count == 0)
                                    {
                                        <span class="text-muted">ярлык не найден</span>
                                    }
                                    else
                                    {
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var label in item.Labels)
                                            {
                                                <span class="badge text-bg-light border">@label.Number: @label.RemainingQuantity.ToString("0.###") шт</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td>
                                    <div>пометка брака: <span class="fw-semibold">@item.DefectLabelPreview</span></div>
                                    <div class="small text-muted">исправимый брак вернется с операции: @item.ReturnOperationHint</div>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group" aria-label="ОТК действия">
                                        <button type="button" class="btn btn-outline-success" disabled>Принять</button>
                                        <button type="button" class="btn btn-outline-warning" disabled>Исправимый</button>
                                        <button type="button" class="btn btn-outline-danger" disabled>Неисправимый</button>
                                        <button type="button" class="btn btn-outline-secondary" disabled>Акт брака</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-light fw-semibold">Заложенная схема</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="fw-semibold">Принятые детали</div>
                    <div class="text-muted small">Основной ярлык продолжает движение без изменений.</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="fw-semibold">Исправимый брак</div>
                    <div class="text-muted small">Количество будет отделяться в ярлык с пометкой “Б”, возвращаться на выбранную операцию и после исправления идти дальше.</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="fw-semibold">История партии</div>
                    <div class="text-muted small">Основной ярлык и ярлык с “Б” сохраняют общий корень, чтобы в истории было видно, что это одна партия.</div>
                </div>
            </div>
        </div>
    </div>
</div>
