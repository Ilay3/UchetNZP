@model AdminMetalMaterialsPageViewModel
@{
    ViewData["Title"] = "Админ: материалы металла";
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-semibold">Администрирование материалов металла</h1>
    <p class="lead mb-0">Добавляйте материалы через интерфейс, без ручных правок в базе данных.</p>
</div>

<div class="card shadow-sm mt-4">
    <div class="card-header bg-light fw-semibold">Связи "Деталь → Материалы (1..8)"</div>
    <div class="card-body">
        <form method="post" asp-action="CreatePartNorm" asp-controller="AdminMetalMaterials" class="row g-3 mb-3">
            @Html.AntiForgeryToken()
            <div class="col-md-4">
                <label class="form-label" for="partLookupInput">Деталь</label>
                <input id="partLookupInput" class="form-control" type="text" list="partLookupOptions" placeholder="Выберите деталь" autocomplete="off" required />
                <datalist id="partLookupOptions"></datalist>
                <input type="hidden" id="partLookupId" name="PartId" required />
            </div>
            <div class="col-md-4">
                <label class="form-label" for="materialLookupInput">Материал</label>
                <input id="materialLookupInput" class="form-control" type="text" list="materialLookupOptions" placeholder="Выберите материал" autocomplete="off" required />
                <datalist id="materialLookupOptions"></datalist>
                <input type="hidden" id="materialLookupId" name="MetalMaterialId" required />
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button class="btn btn-primary w-100" type="submit">Добавить</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-sm table-striped" data-app-pagination="true" data-app-page-size="25">
                <thead>
                    <tr><th>Деталь</th><th>Материал</th><th>Норма детали (только просмотр)</th><th></th></tr>
                </thead>
                <tbody>
                @if (!Model.PartMaterialNorms.Any())
                {
                    <tr><td colspan="4" class="text-muted">Связи пока не добавлены.</td></tr>
                }
                else
                {
                    @foreach (var norm in Model.PartMaterialNorms)
                    {
                        <tr>
                            <td>@norm.PartName (@norm.PartCode)</td>
                            <td>@norm.MaterialName (@norm.MaterialCode)</td>
                            <td>@norm.BaseConsumptionQty.ToString("0.######")</td>
                            <td class="text-end">
                                <form method="post" asp-action="DeletePartNorm" asp-controller="AdminMetalMaterials">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@norm.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Отключить</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a class="btn btn-outline-primary" asp-controller="Admin" asp-action="Index">В общий /admin</a>
</div>

@if (TempData["AdminMetalMaterialsStatus"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}
@if (TempData["AdminMetalMaterialsError"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-semibold">Новый материал</div>
            <div class="card-body">
                <form method="post" asp-action="Create" asp-controller="AdminMetalMaterials">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="CreateModel.Name" class="form-label">Название</label>
                        <input asp-for="CreateModel.Name" class="form-control" />
                        <span asp-validation-for="CreateModel.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CreateModel.Code" class="form-label">Код</label>
                        <input asp-for="CreateModel.Code" class="form-control" />
                        <span asp-validation-for="CreateModel.Code" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CreateModel.Article" class="form-label">Артикул</label>
                        <input asp-for="CreateModel.Article" class="form-control" />
                        <span asp-validation-for="CreateModel.Article" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CreateModel.FullName" class="form-label">Полное наименование 1С</label>
                        <input asp-for="CreateModel.FullName" class="form-control" placeholder="Если пусто, будет использовано название" />
                        <span asp-validation-for="CreateModel.FullName" class="text-danger"></span>
                    </div>

                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateModel.UnitOfMeasure" class="form-label">Ед. 1С</label>
                            <input asp-for="CreateModel.UnitOfMeasure" class="form-control" />
                            <span asp-validation-for="CreateModel.UnitOfMeasure" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateModel.VatRateType" class="form-label">Ставка НДС</label>
                            <input asp-for="CreateModel.VatRateType" class="form-control" />
                            <span asp-validation-for="CreateModel.VatRateType" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateModel.NomenclatureType" class="form-label">Вид номенклатуры</label>
                            <input asp-for="CreateModel.NomenclatureType" class="form-control" />
                            <span asp-validation-for="CreateModel.NomenclatureType" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateModel.NomenclatureGroup" class="form-label">Группа</label>
                            <input asp-for="CreateModel.NomenclatureGroup" class="form-control" />
                            <span asp-validation-for="CreateModel.NomenclatureGroup" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateModel.CountryOfOrigin" class="form-label">Страна происхождения</label>
                            <input asp-for="CreateModel.CountryOfOrigin" class="form-control" placeholder="Россия" />
                            <span asp-validation-for="CreateModel.CountryOfOrigin" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateModel.CustomsDeclarationNumber" class="form-label">Номер ГТД</label>
                            <input asp-for="CreateModel.CustomsDeclarationNumber" class="form-control" />
                            <span asp-validation-for="CreateModel.CustomsDeclarationNumber" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateModel.TnVedCode" class="form-label">Код ТН ВЭД</label>
                            <input asp-for="CreateModel.TnVedCode" class="form-control" />
                            <span asp-validation-for="CreateModel.TnVedCode" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateModel.Okpd2Code" class="form-label">ОКПД2</label>
                            <input asp-for="CreateModel.Okpd2Code" class="form-control" />
                            <span asp-validation-for="CreateModel.Okpd2Code" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateModel.UnitKind" class="form-label">Тип складской единицы</label>
                            <select asp-for="CreateModel.UnitKind" class="form-select">
                                <option value="Meter">Метры</option>
                                <option value="SquareMeter">Квадратные метры</option>
                                <option value="Kilogram">Килограммы</option>
                                <option value="Piece">Штуки</option>
                            </select>
                            <span asp-validation-for="CreateModel.UnitKind" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateModel.StockUnit" class="form-label">Складская единица</label>
                            <input asp-for="CreateModel.StockUnit" class="form-control" placeholder="m, m2, kg, pcs" />
                            <span asp-validation-for="CreateModel.StockUnit" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateModel.MassPerMeterKg" class="form-label">Масса 1м, кг</label>
                            <input asp-for="CreateModel.MassPerMeterKg" class="form-control" type="number" min="0" step="0.001" />
                            <span asp-validation-for="CreateModel.MassPerMeterKg" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateModel.MassPerSquareMeterKg" class="form-label">Масса 1м², кг</label>
                            <input asp-for="CreateModel.MassPerSquareMeterKg" class="form-control" type="number" min="0" step="0.001" />
                            <span asp-validation-for="CreateModel.MassPerSquareMeterKg" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CreateModel.WeightPerUnitKg" class="form-label">Вес 1м / 1м², кг</label>
                        <input asp-for="CreateModel.WeightPerUnitKg" class="form-control" type="number" min="0.001" step="0.001" />
                        <span asp-validation-for="CreateModel.WeightPerUnitKg" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CreateModel.CoefConsumption" class="form-label">Коэффициент расхода</label>
                        <input asp-for="CreateModel.CoefConsumption" class="form-control" type="number" min="0.001" step="0.001" />
                        <span asp-validation-for="CreateModel.CoefConsumption" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CreateModel.Coefficient" class="form-label">Коэффициент металла</label>
                        <input asp-for="CreateModel.Coefficient" class="form-control" type="number" min="0.001" step="0.001" />
                        <span asp-validation-for="CreateModel.Coefficient" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CreateModel.Comment" class="form-label">Комментарий</label>
                        <textarea asp-for="CreateModel.Comment" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="CreateModel.Comment" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="CreateModel.IsService" class="form-check-input" />
                        <label asp-for="CreateModel.IsService" class="form-check-label">Услуга, не товар</label>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="CreateModel.IsActive" class="form-check-input" />
                        <label asp-for="CreateModel.IsActive" class="form-check-label">Активный материал</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Добавить материал</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-semibold">Справочник материалов</div>
            <div class="card-body">
                <div class="row g-2 mb-3">
                    <div class="col-md-6">
                        <input id="materialsSearchInput" type="search" class="form-control" placeholder="Поиск по названию и коду" />
                    </div>
                    <div class="col-md-3">
                        <select id="materialsSortSelect" class="form-select">
                            <option value="name-asc">Сортировка: Название (А-Я)</option>
                            <option value="name-desc">Сортировка: Название (Я-А)</option>
                            <option value="weight-desc">Вес (убыв.)</option>
                            <option value="weight-asc">Вес (возр.)</option>
                        </select>
                    </div>
                    <div class="col-md-3 text-md-end small text-muted d-flex align-items-center justify-content-md-end" id="materialsPagerInfo"></div>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0" id="materialsTable">
                        <thead class="table-light">
                            <tr>
                                <th>Название</th>
                                <th>Код</th>
                                <th>Артикул</th>
                                <th>Ед. 1С</th>
                                <th>Вид/группа</th>
                                <th>1С-реквизиты</th>
                                <th>Вес 1м / 1м², кг</th>
                                <th>Склад</th>
                                <th>Коэффициент</th>
                                <th>Статус</th>
                                <th class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Materials.Count == 0)
                            {
                                <tr>
                                    <td colspan="11" class="text-muted">Материалы пока не добавлены.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var material in Model.Materials)
                                {
                                    <tr data-name="@material.Name.ToLowerInvariant()" data-code="@(material.Code?.ToLowerInvariant() ?? string.Empty)" data-article="@(material.Article?.ToLowerInvariant() ?? string.Empty)" data-weight="@material.WeightPerUnitKg.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                        <td class="fw-semibold">@material.Name</td>
                                        <td>@(string.IsNullOrWhiteSpace(material.Code) ? "—" : material.Code)</td>
                                        <td>@(string.IsNullOrWhiteSpace(material.Article) ? "—" : material.Article)</td>
                                        <td>@material.UnitOfMeasure</td>
                                        <td>
                                            <div>@(string.IsNullOrWhiteSpace(material.NomenclatureType) ? "—" : material.NomenclatureType)</div>
                                            <div class="small text-muted">@(string.IsNullOrWhiteSpace(material.NomenclatureGroup) ? "—" : material.NomenclatureGroup)</div>
                                        </td>
                                        <td>
                                            <div>@(string.IsNullOrWhiteSpace(material.VatRateType) ? "НДС не задан" : material.VatRateType)</div>
                                            <div class="small text-muted">Страна: @(string.IsNullOrWhiteSpace(material.CountryOfOrigin) ? "—" : material.CountryOfOrigin)</div>
                                            <div class="small text-muted">ГТД: @(string.IsNullOrWhiteSpace(material.CustomsDeclarationNumber) ? "—" : material.CustomsDeclarationNumber)</div>
                                            <div class="small text-muted">ТН ВЭД: @(string.IsNullOrWhiteSpace(material.TnVedCode) ? "—" : material.TnVedCode); ОКПД2: @(string.IsNullOrWhiteSpace(material.Okpd2Code) ? "—" : material.Okpd2Code)</div>
                                        </td>
                                        <td>@material.WeightPerUnitKg.ToString("0.###")</td>
                                        <td>
                                            <div>@material.UnitKind / @material.StockUnit</div>
                                            <div class="small text-muted">1м: @material.MassPerMeterKg.ToString("0.###") кг; 1м²: @material.MassPerSquareMeterKg.ToString("0.###") кг</div>
                                            <div class="small text-muted">Расход: @material.CoefConsumption.ToString("0.###")</div>
                                            @if (material.IsService)
                                            {
                                                <span class="app-status app-status--warning">Услуга</span>
                                            }
                                        </td>
                                        <td>@material.Coefficient.ToString("0.###")</td>
                                        <td>
                                            <span class="@(material.IsActive ? "app-status app-status--success" : "app-status app-status--neutral")">
                                                @(material.IsActive ? "Активен" : "Отключен")
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-primary js-edit-material"
                                                    data-id="@material.Id"
                                                    data-name="@material.Name"
                                                    data-full-name="@material.FullName"
                                                    data-code="@material.Code"
                                                    data-article="@material.Article"
                                                    data-unit-of-measure="@material.UnitOfMeasure"
                                                    data-nomenclature-type="@material.NomenclatureType"
                                                    data-nomenclature-group="@material.NomenclatureGroup"
                                                    data-vat-rate-type="@material.VatRateType"
                                                    data-country-of-origin="@material.CountryOfOrigin"
                                                    data-customs-declaration-number="@material.CustomsDeclarationNumber"
                                                    data-tn-ved-code="@material.TnVedCode"
                                                    data-okpd2-code="@material.Okpd2Code"
                                                    data-comment="@material.Comment"
                                                    data-is-service="@material.IsService.ToString().ToLowerInvariant()"
                                                    data-unit-kind="@material.UnitKind"
                                                    data-stock-unit="@material.StockUnit"
                                                    data-mass-per-meter="@material.MassPerMeterKg.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)"
                                                    data-mass-per-square-meter="@material.MassPerSquareMeterKg.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)"
                                                    data-coef-consumption="@material.CoefConsumption.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)"
                                                    data-weight="@material.WeightPerUnitKg.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)"
                                                    data-coefficient="@material.Coefficient.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)"
                                                    data-active="@material.IsActive.ToString().ToLowerInvariant()">
                                                Изменить
                                            </button>
                                            <form method="post" asp-action="Delete" asp-controller="AdminMetalMaterials" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@material.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Удалить материал? Если материал уже используется, он будет только деактивирован.');">Удалить</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="materialsPrevPage">Назад</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="materialsNextPage">Вперёд</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editMaterialModal" tabindex="-1" aria-labelledby="editMaterialModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-action="Update" asp-controller="AdminMetalMaterials">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="editMaterialModalLabel">Редактировать материал</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    <input asp-for="UpdateModel.Id" type="hidden" id="edit-id" />
                    <div class="mb-3">
                        <label asp-for="UpdateModel.Name" class="form-label">Название</label>
                        <input asp-for="UpdateModel.Name" class="form-control" id="edit-name" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateModel.Code" class="form-label">Код</label>
                        <input asp-for="UpdateModel.Code" class="form-control" id="edit-code" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateModel.Article" class="form-label">Артикул</label>
                        <input asp-for="UpdateModel.Article" class="form-control" id="edit-article" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateModel.FullName" class="form-label">Полное наименование 1С</label>
                        <input asp-for="UpdateModel.FullName" class="form-control" id="edit-full-name" />
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateModel.UnitOfMeasure" class="form-label">Ед. 1С</label>
                            <input asp-for="UpdateModel.UnitOfMeasure" class="form-control" id="edit-unit-of-measure" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateModel.VatRateType" class="form-label">Ставка НДС</label>
                            <input asp-for="UpdateModel.VatRateType" class="form-control" id="edit-vat-rate-type" />
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateModel.NomenclatureType" class="form-label">Вид номенклатуры</label>
                            <input asp-for="UpdateModel.NomenclatureType" class="form-control" id="edit-nomenclature-type" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateModel.NomenclatureGroup" class="form-label">Группа</label>
                            <input asp-for="UpdateModel.NomenclatureGroup" class="form-control" id="edit-nomenclature-group" />
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateModel.CountryOfOrigin" class="form-label">Страна происхождения</label>
                            <input asp-for="UpdateModel.CountryOfOrigin" class="form-control" id="edit-country-of-origin" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateModel.CustomsDeclarationNumber" class="form-label">Номер ГТД</label>
                            <input asp-for="UpdateModel.CustomsDeclarationNumber" class="form-control" id="edit-customs-declaration-number" />
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateModel.TnVedCode" class="form-label">Код ТН ВЭД</label>
                            <input asp-for="UpdateModel.TnVedCode" class="form-control" id="edit-tn-ved-code" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateModel.Okpd2Code" class="form-label">ОКПД2</label>
                            <input asp-for="UpdateModel.Okpd2Code" class="form-control" id="edit-okpd2-code" />
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateModel.UnitKind" class="form-label">Тип складской единицы</label>
                            <select asp-for="UpdateModel.UnitKind" class="form-select" id="edit-unit-kind">
                                <option value="Meter">Метры</option>
                                <option value="SquareMeter">Квадратные метры</option>
                                <option value="Kilogram">Килограммы</option>
                                <option value="Piece">Штуки</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateModel.StockUnit" class="form-label">Складская единица</label>
                            <input asp-for="UpdateModel.StockUnit" class="form-control" id="edit-stock-unit" />
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateModel.MassPerMeterKg" class="form-label">Масса 1м, кг</label>
                            <input asp-for="UpdateModel.MassPerMeterKg" class="form-control" type="number" min="0" step="0.001" id="edit-mass-per-meter" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateModel.MassPerSquareMeterKg" class="form-label">Масса 1м², кг</label>
                            <input asp-for="UpdateModel.MassPerSquareMeterKg" class="form-control" type="number" min="0" step="0.001" id="edit-mass-per-square-meter" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateModel.WeightPerUnitKg" class="form-label">Вес 1м / 1м², кг</label>
                        <input asp-for="UpdateModel.WeightPerUnitKg" class="form-control" type="number" min="0.001" step="0.001" id="edit-weight" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateModel.CoefConsumption" class="form-label">Коэффициент расхода</label>
                        <input asp-for="UpdateModel.CoefConsumption" class="form-control" type="number" min="0.001" step="0.001" id="edit-coef-consumption" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateModel.Coefficient" class="form-label">Коэффициент металла</label>
                        <input asp-for="UpdateModel.Coefficient" class="form-control" type="number" min="0.001" step="0.001" id="edit-coefficient" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateModel.Comment" class="form-label">Комментарий</label>
                        <textarea asp-for="UpdateModel.Comment" class="form-control" rows="2" id="edit-comment"></textarea>
                    </div>
                    <div class="form-check mb-1">
                        <input asp-for="UpdateModel.IsService" class="form-check-input" id="edit-is-service" />
                        <label asp-for="UpdateModel.IsService" class="form-check-label">Услуга, не товар</label>
                    </div>
                    <div class="form-check mb-1">
                        <input asp-for="UpdateModel.IsActive" class="form-check-input" id="edit-active" />
                        <label asp-for="UpdateModel.IsActive" class="form-check-label">Активный материал</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">Сохранить изменения</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const namespace = window.UchetNZP || {};
            if (typeof namespace.initSearchableInput === "function") {
                namespace.initSearchableInput({
                    input: document.getElementById("partLookupInput"),
                    datalist: document.getElementById("partLookupOptions"),
                    hiddenInput: document.getElementById("partLookupId"),
                    fetchUrl: "/admin/metal-materials/parts",
                    minChars: 0,
                });

                namespace.initSearchableInput({
                    input: document.getElementById("materialLookupInput"),
                    datalist: document.getElementById("materialLookupOptions"),
                    hiddenInput: document.getElementById("materialLookupId"),
                    fetchUrl: "/admin/metal-materials/materials",
                    minChars: 0,
                });
            }

            const modalElement = document.getElementById("editMaterialModal");
            if (modalElement && typeof bootstrap !== "undefined") {
                const modal = new bootstrap.Modal(modalElement);
                document.querySelectorAll(".js-edit-material").forEach(button => {
                button.addEventListener("click", () => {
                    document.getElementById("edit-id").value = button.dataset.id || "";
                    document.getElementById("edit-name").value = button.dataset.name || "";
                    document.getElementById("edit-full-name").value = button.dataset.fullName || "";
                    document.getElementById("edit-code").value = button.dataset.code || "";
                    document.getElementById("edit-article").value = button.dataset.article || "";
                    document.getElementById("edit-unit-of-measure").value = button.dataset.unitOfMeasure || "кг";
                    document.getElementById("edit-nomenclature-type").value = button.dataset.nomenclatureType || "Материалы";
                    document.getElementById("edit-nomenclature-group").value = button.dataset.nomenclatureGroup || "Металл";
                    document.getElementById("edit-vat-rate-type").value = button.dataset.vatRateType || "НДС 22%";
                    document.getElementById("edit-country-of-origin").value = button.dataset.countryOfOrigin || "";
                    document.getElementById("edit-customs-declaration-number").value = button.dataset.customsDeclarationNumber || "";
                    document.getElementById("edit-tn-ved-code").value = button.dataset.tnVedCode || "";
                    document.getElementById("edit-okpd2-code").value = button.dataset.okpd2Code || "";
                    document.getElementById("edit-comment").value = button.dataset.comment || "";
                    document.getElementById("edit-is-service").checked = (button.dataset.isService || "") === "true";
                    document.getElementById("edit-unit-kind").value = button.dataset.unitKind || "Meter";
                    document.getElementById("edit-stock-unit").value = button.dataset.stockUnit || "m";
                    document.getElementById("edit-mass-per-meter").value = button.dataset.massPerMeter || "";
                    document.getElementById("edit-mass-per-square-meter").value = button.dataset.massPerSquareMeter || "";
                    document.getElementById("edit-coef-consumption").value = button.dataset.coefConsumption || "1";
                    document.getElementById("edit-weight").value = button.dataset.weight || "";
                    document.getElementById("edit-coefficient").value = button.dataset.coefficient || "1";
                    document.getElementById("edit-active").checked = (button.dataset.active || "") === "true";
                    modal.show();
                });
                });
            }

            const rows = Array.from(document.querySelectorAll("#materialsTable tbody tr[data-name]"));
            const searchInput = document.getElementById("materialsSearchInput");
            const sortSelect = document.getElementById("materialsSortSelect");
            const pagerInfo = document.getElementById("materialsPagerInfo");
            const prevButton = document.getElementById("materialsPrevPage");
            const nextButton = document.getElementById("materialsNextPage");
            const pageSize = 20;
            let currentPage = 1;

            function renderMaterialsTable() {
                const term = (searchInput?.value || "").trim().toLowerCase();
                const sorted = rows
                    .filter(row => {
                        const name = row.dataset.name || "";
                        const code = row.dataset.code || "";
                        const article = row.dataset.article || "";
                        return !term || name.includes(term) || code.includes(term) || article.includes(term);
                    })
                    .sort((a, b) => {
                        const mode = sortSelect?.value || "name-asc";
                        if (mode === "name-desc") return (b.dataset.name || "").localeCompare(a.dataset.name || "");
                        if (mode === "weight-desc") return Number(b.dataset.weight || "0") - Number(a.dataset.weight || "0");
                        if (mode === "weight-asc") return Number(a.dataset.weight || "0") - Number(b.dataset.weight || "0");
                        return (a.dataset.name || "").localeCompare(b.dataset.name || "");
                    });

                const totalPages = Math.max(1, Math.ceil(sorted.length / pageSize));
                currentPage = Math.min(currentPage, totalPages);
                const from = (currentPage - 1) * pageSize;
                const to = from + pageSize;
                rows.forEach(row => row.classList.add("d-none"));
                sorted.slice(from, to).forEach(row => row.classList.remove("d-none"));
                if (pagerInfo) pagerInfo.textContent = `Показано ${sorted.length === 0 ? 0 : from + 1}-${Math.min(to, sorted.length)} из ${sorted.length}`;
                if (prevButton) prevButton.disabled = currentPage <= 1;
                if (nextButton) nextButton.disabled = currentPage >= totalPages;
            }

            searchInput?.addEventListener("input", () => { currentPage = 1; renderMaterialsTable(); });
            sortSelect?.addEventListener("change", () => { currentPage = 1; renderMaterialsTable(); });
            prevButton?.addEventListener("click", () => { currentPage -= 1; renderMaterialsTable(); });
            nextButton?.addEventListener("click", () => { currentPage += 1; renderMaterialsTable(); });
            renderMaterialsTable();
        })();
    </script>
}
