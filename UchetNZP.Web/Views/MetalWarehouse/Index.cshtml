@model MetalWarehouseDashboardViewModel
@{
    ViewData["Title"] = "Склад металла";
}

<div class="page-header mb-4">
    <h1 class="display-5 fw-semibold">Склад металла</h1>
    <p class="lead mb-0">Стартовая страница нового модуля управления приходом, остатками и движением металла.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Материалов в справочнике</div>
                <div class="fs-3 fw-semibold">@Model.MaterialsInCatalog</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Единиц металла на складе</div>
                <div class="fs-3 fw-semibold">@Model.MetalUnitsInStockDisplay</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Открытых требований</div>
                <div class="fs-3 fw-semibold">@Model.OpenRequirements</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Движений за сегодня</div>
                <div class="fs-3 fw-semibold">@Model.MovementsToday</div>
            </div>
        </div>
    </div>
</div>

@if (!Model.HasAnyData)
{
    <div class="alert alert-light border mb-4" role="alert">
        <div class="fw-semibold mb-1">Пока нет данных по складу металла.</div>
        <div class="text-muted">Все показатели равны 0. После загрузки справочника и операций модуль начнёт наполняться.</div>
    </div>
}

<div class="row g-3">
    <div class="col-md-6 col-xl-3">
        <a class="card shadow-sm text-decoration-none text-body h-100" asp-controller="MetalWarehouse" asp-action="Receipts">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 fw-semibold">Приход металла</h2>
                <p class="text-muted mb-0">Открыть журнал поступлений металла на склад.</p>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-3">
        <a class="card shadow-sm text-decoration-none text-body h-100" asp-controller="MetalWarehouse" asp-action="Stock">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 fw-semibold">Остатки металла</h2>
                <p class="text-muted mb-0">Открыть текущие остатки по складу металла.</p>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-3">
        <a class="card shadow-sm text-decoration-none text-body h-100" asp-controller="MetalWarehouse" asp-action="Requirements">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 fw-semibold">Требования производства</h2>
                <p class="text-muted mb-0">Открыть список требований на выдачу металла.</p>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-3">
        <a class="card shadow-sm text-decoration-none text-body h-100" asp-controller="MetalWarehouse" asp-action="Movements">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 fw-semibold">История движений</h2>
                <p class="text-muted mb-0">Открыть хронологию операций по модулю металла.</p>
            </div>
        </a>
    </div>
</div>
