@model MetalReceiptListViewModel
@{
    ViewData["Title"] = "Приход металла";
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-semibold">Приход металла</h1>
    <p class="lead mb-0">Журнал поступлений металла на склад.</p>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a class="btn btn-outline-primary" asp-controller="MetalWarehouse" asp-action="Index">На главную модуля</a>
    <a class="btn btn-primary" asp-controller="MetalWarehouse" asp-action="CreateReceipt">Добавить приход</a>
    <a class="btn btn-outline-secondary" asp-controller="MetalWarehouse" asp-action="Stock">Остатки</a>
    <a class="btn btn-outline-secondary" asp-controller="MetalWarehouse" asp-action="Requirements">Требования</a>
    <a class="btn btn-outline-secondary" asp-controller="MetalWarehouse" asp-action="Issues">Выдачи</a>
    <a class="btn btn-outline-secondary" asp-controller="MetalWarehouse" asp-action="Movements">Движения</a>
</div>

@if (TempData["MetalReceiptSuccess"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

<div class="card shadow-sm">
    <div class="card-header bg-light fw-semibold">Приходы</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0" data-app-pagination="true" data-app-page-size="25">
                <thead class="table-light">
                    <tr>
                        <th>Номер</th>
                        <th>Дата</th>
                        <th>Организация</th>
                        <th>Склад</th>
                        <th>Поставщик</th>
                        <th>Документ</th>
                        <th>Дата док.</th>
                        <th>УПД/накладная</th>
                        <th>Партия</th>
                        <th>Металл</th>
                        <th>Ед. склада</th>
                        <th>Кг</th>
                        <th>Цена</th>
                        <th>Сумма без НДС</th>
                        <th>НДС</th>
                        <th>Всего</th>
                        <th>Оригинал</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Receipts.Count == 0)
                    {
                        <tr>
                            <td colspan="17" class="py-4">
                                <div class="fw-semibold">Поступлений пока нет</div>
                                <div class="text-muted">Когда вы добавите первый приход металла, он появится в этой таблице.</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var receipt in Model.Receipts)
                        {
                            <tr role="button" ondblclick="window.location='@Url.Action("ReceiptDetails", "MetalWarehouse", new { id = receipt.Id })'">
                                <td class="fw-semibold">@receipt.ReceiptNumber</td>
                                <td>@receipt.ReceiptDate.ToString("dd.MM.yyyy")</td>
                                <td>@receipt.OrganizationName</td>
                                <td>@receipt.WarehouseName</td>
                                <td>@(string.IsNullOrWhiteSpace(receipt.SupplierDisplay) ? "—" : receipt.SupplierDisplay)</td>
                                <td>@(string.IsNullOrWhiteSpace(receipt.SupplierDocumentNumber) ? "—" : receipt.SupplierDocumentNumber)</td>
                                <td>@(receipt.SupplierDocumentDate.HasValue ? receipt.SupplierDocumentDate.Value.ToString("dd.MM.yyyy") : "—")</td>
                                <td>@(string.IsNullOrWhiteSpace(receipt.InvoiceOrUpiNumber) ? "—" : receipt.InvoiceOrUpiNumber)</td>
                                <td>@(string.IsNullOrWhiteSpace(receipt.BatchNumber) ? "—" : receipt.BatchNumber)</td>
                                <td>@receipt.MaterialsSummary</td>
                                <td>@receipt.TotalQuantity</td>
                                <td>@receipt.TotalPassportWeightKg.ToString("0.###")</td>
                                <td>@receipt.PricePerKg.ToString("0.####")</td>
                                <td>@receipt.AmountWithoutVat.ToString("0.00")</td>
                                <td>@receipt.VatAmount.ToString("0.00")</td>
                                <td>@receipt.TotalAmountWithVat.ToString("0.00")</td>
                                <td>
                                    @if (receipt.HasOriginalDocument)
                                    {
                                        <a class="btn btn-sm btn-outline-success"
                                           asp-controller="MetalWarehouse"
                                           asp-action="ReceiptOriginalDocument"
                                           asp-route-id="@receipt.Id"
                                           onclick="event.stopPropagation();">
                                            PDF
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
