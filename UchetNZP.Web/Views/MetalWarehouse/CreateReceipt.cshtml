@model MetalReceiptCreateViewModel
@{
    ViewData["Title"] = "Добавить приход металла";
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-semibold">Добавить приход металла</h1>
    <p class="lead mb-0">Заполните документ и укажите размеры для каждой единицы.</p>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a class="btn btn-outline-primary" asp-controller="MetalWarehouse" asp-action="Receipts">К списку приходов</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" class="row g-3" id="metalReceiptForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @if (Model.Materials.Count == 0)
            {
                <div class="col-12">
                    <div class="alert alert-warning mb-0" role="alert">
                        Нет доступных материалов. Добавьте материалы в справочник, чтобы создать приход.
                    </div>
                </div>
            }

            <div class="col-md-4">
                <label asp-for="ReceiptDate" class="form-label"></label>
                <input asp-for="ReceiptDate" class="form-control" type="date" />
                <span asp-validation-for="ReceiptDate" class="text-danger"></span>
            </div>

            <div class="col-md-8">
                <label asp-for="SupplierOrSource" class="form-label">Поставщик / источник</label>
                <input asp-for="SupplierOrSource" class="form-control" />
                <span asp-validation-for="SupplierOrSource" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="MetalMaterialId" class="form-label">Материал</label>
                <select asp-for="MetalMaterialId" asp-items="Model.Materials" class="form-select" id="materialSelect">
                    <option value="">Выберите материал</option>
                </select>
                <span asp-validation-for="MetalMaterialId" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="PassportWeightKg" class="form-label">Паспортная масса, кг</label>
                <input asp-for="PassportWeightKg" class="form-control" type="number" min="0.001" step="0.001" />
                <span asp-validation-for="PassportWeightKg" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="ActualWeightKg" class="form-label">Фактическая масса, кг</label>
                <input asp-for="ActualWeightKg" class="form-control" type="number" min="0.001" step="0.001" />
                <span asp-validation-for="ActualWeightKg" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="Quantity" class="form-label">Количество</label>
                <input asp-for="Quantity" class="form-control" type="number" min="1" step="1" id="quantityInput" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="BatchNumber" class="form-label">Партия</label>
                <input asp-for="BatchNumber" class="form-control" />
                <span asp-validation-for="BatchNumber" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="ProfileType" class="form-label">Тип проката</label>
                <select asp-for="ProfileType" class="form-select" id="profileTypeSelect">
                    <option value="sheet">Лист</option>
                    <option value="rod">Круг/пруток</option>
                    <option value="pipe">Труба</option>
                </select>
            </div>

            <div class="col-md-3 profile-sheet">
                <label asp-for="ThicknessMm" class="form-label">Толщина, мм</label>
                <input asp-for="ThicknessMm" class="form-control" type="number" min="0.001" step="0.001" />
            </div>
            <div class="col-md-3 profile-sheet">
                <label asp-for="WidthMm" class="form-label">Ширина, мм</label>
                <input asp-for="WidthMm" class="form-control" type="number" min="0.001" step="0.001" />
            </div>
            <div class="col-md-3 profile-sheet profile-rod profile-pipe">
                <label asp-for="LengthMm" class="form-label">Длина, мм</label>
                <input asp-for="LengthMm" class="form-control" type="number" min="0.001" step="0.001" />
            </div>
            <div class="col-md-3 profile-rod profile-pipe">
                <label asp-for="DiameterMm" class="form-label">Диаметр, мм</label>
                <input asp-for="DiameterMm" class="form-control" type="number" min="0.001" step="0.001" />
            </div>
            <div class="col-md-3 profile-pipe">
                <label asp-for="WallThicknessMm" class="form-label">Стенка, мм</label>
                <input asp-for="WallThicknessMm" class="form-control" type="number" min="0.001" step="0.001" />
            </div>

            <div class="col-12">
                <label asp-for="Comment" class="form-label">Комментарий</label>
                <textarea asp-for="Comment" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>

            <div class="col-12">
                <div class="card bg-light border-0">
                    <div class="card-body">
                        <h2 class="h5 mb-3">Поштучные размеры</h2>
                        <div id="unitsContainer" class="row g-3">
                            @for (var i = 0; i < Model.Units.Count; i++)
                            {
                                var itemIndex = Model.Units[i].ItemIndex > 0 ? Model.Units[i].ItemIndex : i + 1;
                                <div class="col-md-6">
                                    <div class="border rounded p-3 bg-white">
                                        <div class="fw-semibold mb-2">Единица @itemIndex</div>
                                        <input asp-for="Units[i].ItemIndex" type="hidden" value="@itemIndex" />
                                        <input asp-for="Units[i].SizeValue" class="form-control" type="number" min="0.001" step="0.001" data-index="@itemIndex" />
                                        <span asp-validation-for="Units[i].SizeValue" class="text-danger"></span>
                                    </div>
                                </div>
                            }
                        </div>
                        <span asp-validation-for="Units" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Сохранить приход</button>
                <a class="btn btn-outline-secondary" asp-controller="MetalWarehouse" asp-action="Receipts">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/metal-receipt-create.js" asp-append-version="true"></script>
}

<script id="materialProfileMap" type="application/json">@System.Text.Json.JsonSerializer.Serialize(Model.MaterialProfileTypes)</script>
