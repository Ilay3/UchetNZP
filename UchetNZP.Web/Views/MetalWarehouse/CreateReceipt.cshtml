@model MetalReceiptCreateViewModel
@{
    ViewData["Title"] = "Добавить приход металла";
    var materialOptionsJson = System.Text.Json.JsonSerializer.Serialize(Model.Materials.Select(x => new { id = x.Value, text = x.Text }));
    var supplierOptionsJson = System.Text.Json.JsonSerializer.Serialize(Model.Suppliers.Select(x => new { id = x.Value, text = x.Text }));
    var materialUnitKindJson = System.Text.Json.JsonSerializer.Serialize(Model.MaterialUnitKinds);
    var materialCoefficientJson = System.Text.Json.JsonSerializer.Serialize(Model.MaterialCoefficients);
    var materialWeightPerUnitJson = System.Text.Json.JsonSerializer.Serialize(Model.MaterialWeightPerUnitKg);
    var selectedSupplierText = Model.Suppliers.FirstOrDefault(x => x.Value == Model.SupplierId?.ToString())?.Text ?? Model.SupplierInputText ?? string.Empty;
    var priceValue = Model.PricePerKg?.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-semibold">Добавить приход металла</h1>
    <p class="lead mb-0">Структура шапки и строк приведена к документу 1С: поставщик, склад, договор, счета и строки номенклатуры в кг.</p>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a class="btn btn-outline-primary" asp-controller="MetalWarehouse" asp-action="Receipts">К списку приходов</a>
</div>

@if (TempData["MetalReceiptSuccess"] is string success)
{
    var createdId = TempData["MetalReceiptId"]?.ToString();
    var createdNumber = TempData["MetalReceiptNumber"]?.ToString();
    <div class="alert alert-success d-flex flex-column gap-2" role="alert">
        <div class="fw-semibold">@success (@createdNumber)</div>
        @if (Guid.TryParse(createdId, out var receiptId))
        {
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-sm btn-success" asp-action="ReceiptDetails" asp-route-id="@receiptId">Открыть карточку</a>
                <a class="btn btn-sm btn-outline-success" asp-action="ReceiptDocument" asp-route-id="@receiptId">Скачать PDF накладную</a>
            </div>
        }
    </div>
}

<form method="post" asp-controller="MetalWarehouse" asp-action="CreateReceipt" class="row g-3" id="metalReceiptForm" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    @if (Model.Materials.Count == 0)
    {
        <div class="col-12">
            <div class="alert alert-warning mb-0" role="alert">
                Нет доступных материалов.
                <a asp-controller="AdminMetalMaterials" asp-action="Index" class="alert-link">Добавьте материалы в админ-справочнике</a>,
                чтобы создать приход.
            </div>
        </div>
    }

    <div class="col-md-2">
        <label asp-for="ReceiptDate" class="form-label">Дата прихода</label>
        <input asp-for="ReceiptDate" class="form-control form-control-lg" type="date" />
        <span asp-validation-for="ReceiptDate" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="OrganizationName" class="form-label">Организация</label>
        <input asp-for="OrganizationName" class="form-control form-control-lg" />
        <span asp-validation-for="OrganizationName" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="WarehouseName" class="form-label">Склад</label>
        <input asp-for="WarehouseName" class="form-control form-control-lg" />
        <span asp-validation-for="WarehouseName" class="text-danger"></span>
    </div>

    <div class="col-md-2">
        <label asp-for="OperationType" class="form-label">Операция 1С</label>
        <input asp-for="OperationType" class="form-control form-control-lg" />
        <span asp-validation-for="OperationType" class="text-danger"></span>
    </div>

    <div class="col-md-2">
        <label asp-for="CurrencyCode" class="form-label">Валюта</label>
        <input asp-for="CurrencyCode" class="form-control form-control-lg text-uppercase" maxlength="3" />
        <span asp-validation-for="CurrencyCode" class="text-danger"></span>
    </div>

    <div class="col-md-2">
        <label asp-for="BatchNumber" class="form-label">Партия</label>
        <input asp-for="BatchNumber" class="form-control form-control-lg" maxlength="32" placeholder="Партия/серия" />
        <span asp-validation-for="BatchNumber" class="text-danger"></span>
    </div>

    <div class="col-md-2">
        <label asp-for="ResponsibleUserName" class="form-label">Ответственный</label>
        <input asp-for="ResponsibleUserName" class="form-control form-control-lg" readonly />
        <span asp-validation-for="ResponsibleUserName" class="text-danger"></span>
    </div>

    <div class="col-md-4 position-relative">
        <label class="form-label">Поставщик</label>
        <div class="input-group input-group-lg minimal-plus-input">
            <input class="form-control"
                   type="text"
                   name="SupplierInputText"
                   value="@selectedSupplierText"
                   placeholder="ИНН или наименование"
                   autocomplete="off"
                   data-supplier-input />
        </div>
        <div class="list-group position-absolute w-100 shadow-sm d-none"
             style="z-index: 1050; max-height: 260px; overflow-y: auto;"
             data-supplier-suggestions></div>
        <input type="hidden" asp-for="SupplierId" data-supplier-id />
        <span asp-validation-for="SupplierId" class="text-danger"></span>
    </div>

    <div class="col-md-2">
        <label asp-for="SupplierDocumentNumber" class="form-label">№ документа</label>
        <input asp-for="SupplierDocumentNumber" class="form-control form-control-lg" maxlength="128" />
        <span asp-validation-for="SupplierDocumentNumber" class="text-danger"></span>
    </div>
    <div class="col-md-2">
        <label asp-for="SupplierDocumentDate" class="form-label">Дата документа</label>
        <input asp-for="SupplierDocumentDate" class="form-control form-control-lg" type="date" />
        <span asp-validation-for="SupplierDocumentDate" class="text-danger"></span>
    </div>
    <div class="col-md-2">
        <label asp-for="InvoiceOrUpiNumber" class="form-label">Накладная, УПД №</label>
        <input asp-for="InvoiceOrUpiNumber" class="form-control form-control-lg" maxlength="128" />
    </div>
    <div class="col-md-2">
        <label asp-for="ContractName" class="form-label">Договор</label>
        <input asp-for="ContractName" class="form-control form-control-lg" maxlength="256" />
    </div>
    <div class="col-md-2">
        <label asp-for="AccountingAccount" class="form-label">Счет учета</label>
        <input asp-for="AccountingAccount" class="form-control form-control-lg" readonly />
    </div>
    <div class="col-md-2">
        <label asp-for="VatAccount" class="form-label">Счет НДС</label>
        <input asp-for="VatAccount" class="form-control form-control-lg" readonly />
    </div>
    <div class="col-md-2">
        <label asp-for="SettlementAccount" class="form-label">Счет расчетов</label>
        <input asp-for="SettlementAccount" class="form-control form-control-lg" readonly />
    </div>
    <div class="col-md-2">
        <label asp-for="AdvanceAccount" class="form-label">Счет авансов</label>
        <input asp-for="AdvanceAccount" class="form-control form-control-lg" readonly />
    </div>

    <input asp-for="PricePerKg" type="hidden" value="@priceValue" data-price-input />

    <div class="col-12">
        <div class="row g-2 receipt-financial-summary" data-financial-summary data-vat-rate="@Model.VatRatePercent.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture)">
            <div class="col-md-3">
                <div class="border rounded-3 bg-light p-3 h-100">
                    <div class="small text-uppercase text-muted">Масса по паспорту</div>
                    <div class="fs-5 fw-semibold"><span data-financial-passport-weight>@Model.Items.Sum(x => x.PassportWeightKg ?? 0m).ToString("0.###")</span> кг</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded-3 bg-light p-3 h-100">
                    <div class="small text-uppercase text-muted">Сумма без НДС</div>
                    <div class="fs-5 fw-semibold"><span data-financial-without-vat>@Model.AmountWithoutVat.ToString("0.00")</span> руб.</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded-3 bg-light p-3 h-100">
                    <div class="small text-uppercase text-muted">НДС @Model.VatRatePercent.ToString("0.##")%</div>
                    <div class="fs-5 fw-semibold"><span data-financial-vat>@Model.VatAmount.ToString("0.00")</span> руб.</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded-3 bg-light p-3 h-100">
                    <div class="small text-uppercase text-muted">Всего с НДС</div>
                    <div class="fs-5 fw-semibold"><span data-financial-total>@Model.TotalAmountWithVat.ToString("0.00")</span> руб.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <label asp-for="OriginalDocumentPdf" class="form-label">Оригинал документа</label>
        <input asp-for="OriginalDocumentPdf" class="form-control form-control-lg" type="file" accept=".pdf,.docx,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document" />
        <div class="form-text">PDF или DOCX поставщика. Потом его можно скачать из карточки прихода.</div>
        <span asp-validation-for="OriginalDocumentPdf" class="text-danger"></span>
    </div>

    <div class="col-md-7">
        <label asp-for="Comment" class="form-label">Комментарий</label>
        <textarea asp-for="Comment" class="form-control" rows="2" placeholder="Примечание к приходу"></textarea>
        <span asp-validation-for="Comment" class="text-danger"></span>
    </div>

    <div class="col-12">
        <div class="d-flex align-items-center justify-content-between gap-3 mb-2">
            <h2 class="h4 mb-0">Металлы в документе</h2>
            <button type="button" class="btn btn-outline-primary" id="addReceiptLine">Добавить металл</button>
        </div>

        <div id="receiptItemsContainer" class="d-flex flex-column gap-3">
            @for (var i = 0; i < Model.Items.Count; i++)
            {
                var line = Model.Items[i];
                var selectedMaterialText = Model.Materials.FirstOrDefault(x => x.Value == line.MetalMaterialId?.ToString())?.Text ?? string.Empty;
                var averageClass = line.UseAverageSize ? string.Empty : "d-none";
                var unitClass = line.UseAverageSize ? "d-none" : string.Empty;
                var weightValue = line.PassportWeightKg?.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
                var averageSizeValue = line.AverageSizeValue?.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
                <section class="card shadow-sm border-0 receipt-line" data-receipt-line data-line-index="@i">
                    <div class="card-header bg-light-subtle border-bottom-0">
                        <div class="d-flex align-items-center justify-content-between gap-3">
                            <button type="button" class="btn btn-link text-decoration-none p-0 text-start flex-grow-1 fw-semibold" data-line-toggle>
                                <span data-line-title>Металл @(i + 1)</span>
                                <small class="text-muted ms-2" data-line-summary>Не заполнено</small>
                            </button>
                            <button type="button" class="btn btn-outline-danger btn-sm" data-remove-line>Убрать</button>
                        </div>
                    </div>

                    <div class="card-body row g-3" data-line-body>
                        <div class="col-lg-8 position-relative">
                            <label class="form-label">Материал</label>
                            <div class="input-group input-group-lg minimal-plus-input">
                                <input class="form-control"
                                       type="text"
                                   value="@selectedMaterialText"
                                   placeholder="Начните писать название или код"
                                   autocomplete="off"
                                       name="Items[@i].MaterialInputText"
                                       data-material-input />
                            </div>
                            <div class="list-group position-absolute w-100 shadow-sm d-none"
                                 style="z-index: 1050; max-height: 260px; overflow-y: auto;"
                                 data-material-suggestions></div>
                            <input type="hidden"
                                   name="Items[@i].MetalMaterialId"
                                   value="@line.MetalMaterialId"
                                   data-material-id />
                            <span class="text-danger field-validation-valid" data-valmsg-for="Items[@i].MetalMaterialId" data-valmsg-replace="true"></span>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Цена, руб/кг</label>
                            <input class="form-control form-control-lg"
                                   type="text"
                                   inputmode="decimal"
                                   pattern="^\d+([,.]\d{1,4})?$"
                                   name="Items[@i].PricePerKg"
                                   value="@line.PricePerKg?.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture)"
                                   data-line-price-input />
                            <span class="text-danger field-validation-valid" data-valmsg-for="Items[@i].PricePerKg" data-valmsg-replace="true"></span>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Количество 1С, кг</label>
                            <input class="form-control form-control-lg"
                                   type="number"
                                   min="0.001"
                                   step="0.001"
                                   name="Items[@i].PassportWeightKg"
                                   value="@weightValue"
                                   data-weight-input />
                            <span class="text-danger field-validation-valid" data-valmsg-for="Items[@i].PassportWeightKg" data-valmsg-replace="true"></span>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Складских единиц, шт</label>
                            <input class="form-control form-control-lg"
                                   type="number"
                                   min="1"
                                   step="1"
                                   name="Items[@i].Quantity"
                                   value="@line.Quantity"
                                   data-quantity-input />
                            <span class="text-danger field-validation-valid" data-valmsg-for="Items[@i].Quantity" data-valmsg-replace="true"></span>
                        </div>
                        <div class="col-12">
                            <div class="border rounded-3 p-3 bg-white" data-line-financial-summary>
                                <div class="row g-3">
                                    <div class="col-md-3"><div class="small text-muted">Цена, руб/кг</div><div class="fw-semibold" data-line-price>0,00</div></div>
                                    <div class="col-md-3"><div class="small text-muted">Масса по паспорту</div><div class="fw-semibold"><span data-line-passport-weight>0</span> кг</div></div>
                                    <div class="col-md-2"><div class="small text-muted">Сумма без НДС</div><div class="fw-semibold"><span data-line-without-vat>0,00</span> руб.</div></div>
                                    <div class="col-md-2"><div class="small text-muted">НДС 22%</div><div class="fw-semibold"><span data-line-vat>0,00</span> руб.</div></div>
                                    <div class="col-md-2"><div class="small text-muted">Всего с НДС</div><div class="fw-semibold"><span data-line-total>0,00</span> руб.</div></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <input type="hidden" name="Items[@i].UseAverageSize" value="false" />
                            <div class="form-check form-switch">
                                <input class="form-check-input"
                                       type="checkbox"
                                       role="switch"
                                       name="Items[@i].UseAverageSize"
                                       value="true"
                                       @(line.UseAverageSize ? "checked" : string.Empty)
                                       data-average-checkbox />
                                <label class="form-check-label fw-semibold">Размер одной строкой</label>
                            </div>
                            <div class="form-text">Можно оставить пустым: складской размер будет рассчитан из веса и коэффициента материала.</div>
                        </div>

                        <div class="col-md-4 @averageClass" data-average-section>
                            <label class="form-label">Средний размер, <span data-unit-text>м</span></label>
                            <input class="form-control form-control-lg"
                                   type="number"
                                   min="0.001"
                                   step="0.001"
                                   name="Items[@i].AverageSizeValue"
                                   value="@averageSizeValue"
                                   data-average-size-input />
                            <span class="text-danger field-validation-valid" data-valmsg-for="Items[@i].AverageSizeValue" data-valmsg-replace="true"></span>
                        </div>

                        <div class="col-12 @unitClass" data-units-section>
                            <div class="row g-3">
                                <div class="col-lg-8">
                                    <div class="fw-semibold mb-2">Размер каждой штуки, <span data-unit-text>м</span></div>
                                    <div class="row g-2" data-units-container>
                                @for (var unitIndex = 0; unitIndex < line.Units.Count; unitIndex++)
                                {
                                    var unit = line.Units[unitIndex];
                                    var itemIndex = unit.ItemIndex > 0 ? unit.ItemIndex : unitIndex + 1;
                                    var unitSizeValue = unit.SizeValue?.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
                                    <div class="col-sm-6 col-lg-3">
                                        <label class="form-label small mb-1">Штука @itemIndex</label>
                                        <input type="hidden" name="Items[@i].Units[@unitIndex].ItemIndex" value="@itemIndex" />
                                        <input class="form-control"
                                               type="number"
                                               min="0.001"
                                               step="0.001"
                                               name="Items[@i].Units[@unitIndex].SizeValue"
                                               value="@unitSizeValue"
                                               data-unit-size
                                               data-index="@itemIndex" />
                                    </div>
                                }
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="border rounded-3 bg-light p-3 h-100">
                                        <div class="fw-semibold mb-2">Справка по массе</div>
                                        <div class="small text-muted d-flex flex-column gap-1" data-weight-info>
                                            <div>Вес 1м/1м²: <span data-info-weight-per-unit>—</span> кг</div>
                                            <div>Коэффициент: <span data-info-coefficient>—</span></div>
                                            <div>Сумма размеров: <span data-info-total-size>—</span> <span data-unit-text>м</span></div>
                                            <div>Расчётная: <span data-info-calculated>—</span> кг</div>
                                            <div>Паспортная: <span data-info-passport>—</span> кг</div>
                                            <div>Отклонение: <span data-info-deviation>—</span> кг</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <span class="text-danger field-validation-valid" data-valmsg-for="Items[@i].Units" data-valmsg-replace="true"></span>
                        </div>
                    </div>
                </section>
            }
        </div>
    </div>

    <div class="col-12 d-flex gap-2 flex-wrap">
        <button type="submit" name="submitAction" value="save" class="btn btn-primary btn-lg">Сохранить приход</button>
        <a class="btn btn-outline-secondary btn-lg" asp-controller="MetalWarehouse" asp-action="Receipts">Отмена</a>
    </div>
</form>
<template id="receiptLineTemplate">
    <section class="card shadow-sm border-0 receipt-line" data-receipt-line data-line-index="__index__">
        <div class="card-header bg-light-subtle border-bottom-0">
            <div class="d-flex align-items-center justify-content-between gap-3">
                <button type="button" class="btn btn-link text-decoration-none p-0 text-start flex-grow-1 fw-semibold" data-line-toggle>
                    <span data-line-title>Металл __number__</span>
                    <small class="text-muted ms-2" data-line-summary>Не заполнено</small>
                </button>
                <button type="button" class="btn btn-outline-danger btn-sm" data-remove-line>Убрать</button>
            </div>
        </div>

        <div class="card-body row g-3" data-line-body>
            <div class="col-lg-8 position-relative">
                <label class="form-label">Материал</label>
                <div class="input-group input-group-lg minimal-plus-input">
                    <input class="form-control" type="text" placeholder="Начните писать название или код" autocomplete="off" name="Items[__index__].MaterialInputText" data-material-input />
                </div>
                <div class="list-group position-absolute w-100 shadow-sm d-none" style="z-index: 1050; max-height: 260px; overflow-y: auto;" data-material-suggestions></div>
                <input type="hidden" name="Items[__index__].MetalMaterialId" data-material-id />
                <span class="text-danger field-validation-valid" data-valmsg-for="Items[__index__].MetalMaterialId" data-valmsg-replace="true"></span>
            </div>

            <div class="col-md-2">
                <label class="form-label">Цена, руб/кг</label>
                <input class="form-control form-control-lg" type="text" inputmode="decimal" pattern="^\d+([,.]\d{1,4})?$" name="Items[__index__].PricePerKg" data-line-price-input />
                <span class="text-danger field-validation-valid" data-valmsg-for="Items[__index__].PricePerKg" data-valmsg-replace="true"></span>
            </div>

            <div class="col-md-2">
                <label class="form-label">Количество 1С, кг</label>
                <input class="form-control form-control-lg" type="number" min="0.001" step="0.001" name="Items[__index__].PassportWeightKg" data-weight-input />
                <span class="text-danger field-validation-valid" data-valmsg-for="Items[__index__].PassportWeightKg" data-valmsg-replace="true"></span>
            </div>

            <div class="col-md-2">
                <label class="form-label">Складских единиц, шт</label>
                <input class="form-control form-control-lg" type="number" min="1" step="1" name="Items[__index__].Quantity" value="1" data-quantity-input />
                <span class="text-danger field-validation-valid" data-valmsg-for="Items[__index__].Quantity" data-valmsg-replace="true"></span>
            </div>
                        <div class="col-12">
                            <div class="border rounded-3 p-3 bg-white" data-line-financial-summary>
                                <div class="row g-3">
                                    <div class="col-md-3"><div class="small text-muted">Цена, руб/кг</div><div class="fw-semibold" data-line-price>0,00</div></div>
                                    <div class="col-md-3"><div class="small text-muted">Масса по паспорту</div><div class="fw-semibold"><span data-line-passport-weight>0</span> кг</div></div>
                                    <div class="col-md-2"><div class="small text-muted">Сумма без НДС</div><div class="fw-semibold"><span data-line-without-vat>0,00</span> руб.</div></div>
                                    <div class="col-md-2"><div class="small text-muted">НДС 22%</div><div class="fw-semibold"><span data-line-vat>0,00</span> руб.</div></div>
                                    <div class="col-md-2"><div class="small text-muted">Всего с НДС</div><div class="fw-semibold"><span data-line-total>0,00</span> руб.</div></div>
                                </div>
                            </div>
                        </div>

            <div class="col-12">
                <input type="hidden" name="Items[__index__].UseAverageSize" value="false" />
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" name="Items[__index__].UseAverageSize" value="true" checked data-average-checkbox />
                    <label class="form-check-label fw-semibold">Размер одной строкой</label>
                </div>
                <div class="form-text">Можно оставить пустым: складской размер будет рассчитан из веса и коэффициента материала.</div>
            </div>

            <div class="col-md-4" data-average-section>
                <label class="form-label">Средний размер, <span data-unit-text>м</span></label>
                <input class="form-control form-control-lg" type="number" min="0.001" step="0.001" name="Items[__index__].AverageSizeValue" data-average-size-input />
                <span class="text-danger field-validation-valid" data-valmsg-for="Items[__index__].AverageSizeValue" data-valmsg-replace="true"></span>
            </div>

            <div class="col-12 d-none" data-units-section>
                <div class="row g-3">
                    <div class="col-lg-8">
                        <div class="fw-semibold mb-2">Размер каждой штуки, <span data-unit-text>м</span></div>
                        <div class="row g-2" data-units-container></div>
                    </div>
                    <div class="col-lg-4">
                        <div class="border rounded-3 bg-light p-3 h-100">
                            <div class="fw-semibold mb-2">Справка по массе</div>
                            <div class="small text-muted d-flex flex-column gap-1" data-weight-info>
                                <div>Вес 1м/1м²: <span data-info-weight-per-unit>—</span> кг</div>
                                <div>Коэффициент: <span data-info-coefficient>—</span></div>
                                <div>Сумма размеров: <span data-info-total-size>—</span> <span data-unit-text>м</span></div>
                                <div>Расчётная: <span data-info-calculated>—</span> кг</div>
                                <div>Паспортная: <span data-info-passport>—</span> кг</div>
                                <div>Отклонение: <span data-info-deviation>—</span> кг</div>
                            </div>
                        </div>
                    </div>
                </div>
                <span class="text-danger field-validation-valid" data-valmsg-for="Items[__index__].Units" data-valmsg-replace="true"></span>
            </div>
        </div>
    </section>
</template>


<style>
    .receipt-line[data-collapsed="true"] [data-line-body] { display:none; }
    .receipt-line [data-line-toggle] { color: var(--bs-body-color); }
    .receipt-line [data-line-toggle]:hover { color: var(--bs-primary); }
    .minimal-plus-input .btn { min-width: 3rem; font-weight: 600; }
    .receipt-financial-summary .border { border-color: #dfe3e8 !important; background: #fff !important; }
    .receipt-financial-summary .fs-5 { letter-spacing: .01em; }
</style>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/metal-receipt-create.js" asp-append-version="true"></script>
}

<script id="materialOptionsJson" type="application/json">@Html.Raw(materialOptionsJson)</script>
<script id="supplierOptionsJson" type="application/json">@Html.Raw(supplierOptionsJson)</script>
<script id="materialUnitKindMap" type="application/json">@Html.Raw(materialUnitKindJson)</script>
<script id="materialCoefficientMap" type="application/json">@Html.Raw(materialCoefficientJson)</script>
<script id="materialWeightPerUnitMap" type="application/json">@Html.Raw(materialWeightPerUnitJson)</script>
<script id="receiptDebugContext" type="application/json">@System.Text.Json.JsonSerializer.Serialize(new
{
    IsPostBack = string.Equals(Context.Request.Method, "POST", StringComparison.OrdinalIgnoreCase),
    ModelStateIsValid = ViewData.ModelState.IsValid,
    Errors = ViewData.ModelState
        .Where(x => x.Value?.Errors.Count > 0)
        .SelectMany(x => x.Value!.Errors.Select(error => new
        {
            Field = x.Key,
            Message = error.ErrorMessage,
        }))
        .ToList(),
})</script>
