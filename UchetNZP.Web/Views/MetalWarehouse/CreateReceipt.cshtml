@model MetalReceiptCreateViewModel
@{
    ViewData["Title"] = "Добавить приход металла";
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-semibold">Добавить приход металла</h1>
    <p class="lead mb-0">Заполните документ по шагам — все поля ниже снабжены подсказками.</p>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a class="btn btn-outline-primary" asp-controller="MetalWarehouse" asp-action="Receipts">К списку приходов</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" asp-controller="MetalWarehouse" asp-action="CreateReceipt" class="row g-3" id="metalReceiptForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @if (Model.Materials.Count == 0)
            {
                <div class="col-12">
                    <div class="alert alert-warning mb-0" role="alert">
                        Нет доступных материалов.
                        <a asp-controller="AdminMetalMaterials" asp-action="Index" class="alert-link">Добавьте материалы в админ-справочнике</a>,
                        чтобы создать приход.
                    </div>
                </div>
            }

            <div class="col-md-4">
                <label asp-for="ReceiptDate" class="form-label">Дата прихода</label>
                <input asp-for="ReceiptDate" class="form-control" type="date" />
                <div class="form-text">Укажите фактическую дату поступления металла на склад.</div>
                <span asp-validation-for="ReceiptDate" class="text-danger"></span>
            </div>

            <div class="col-md-6 position-relative">
                <label class="form-label" for="materialInput">Материал</label>
                <input id="materialInput"
                       class="form-control"
                       type="text"
                       placeholder="Например: Лист Ст3 3мм"
                       autocomplete="off"
                       aria-describedby="materialSearchHelp"
                       value="@(Model.Materials.FirstOrDefault(x => x.Value == Model.MetalMaterialId?.ToString())?.Text ?? string.Empty)" />
                <datalist id="materialOptions">
                    @foreach (var material in Model.Materials)
                    {
                        <option value="@material.Text" data-id="@material.Value"></option>
                    }
                </datalist>
                <div id="materialSuggestions" class="list-group position-absolute w-100 shadow-sm d-none" style="z-index: 1050; max-height: 260px; overflow-y: auto;"></div>
                <input asp-for="MetalMaterialId" type="hidden" id="materialId" />
                <div class="form-text" id="materialSearchHelp">Начните вводить название или код, затем выберите вариант из списка.</div>
                <span asp-validation-for="MetalMaterialId" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="PassportWeightKg" class="form-label">Паспортная масса, кг</label>
                <input asp-for="PassportWeightKg" class="form-control" type="number" min="0.001" step="0.001" />
                <div class="form-text">Введите общий вес по документам поставщика (например, 1250.5).</div>
                <span asp-validation-for="PassportWeightKg" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="Quantity" class="form-label">Количество</label>
                <input asp-for="Quantity" class="form-control" type="number" min="1" step="1" />
                <div class="form-text">Сколько отдельных единиц поступило: листов, труб или прутков.</div>
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <div class="col-12">
                <label asp-for="Comment" class="form-label">Комментарий</label>
                <textarea asp-for="Comment" class="form-control" rows="2"></textarea>
                <div class="form-text">Необязательно. Можно указать номер накладной, поставщика или примечание.</div>
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>

            <div class="col-12">
                <div class="card bg-light border-0">
                    <div class="card-body">
                        <h2 class="h5 mb-3">Поштучные размеры</h2>
                        <div class="text-muted small mb-2">
                            Для каждой единицы укажите размер в <span id="unitTextHint">ед. изм.</span>.
                            Ниже сразу показывается, как размер попадёт в этикетку.
                        </div>
                        <div id="unitsContainer" class="row g-3">
                            @for (var i = 0; i < Model.Units.Count; i++)
                            {
                                var itemIndex = Model.Units[i].ItemIndex > 0 ? Model.Units[i].ItemIndex : i + 1;
                                <div class="col-md-6">
                                    <div class="border rounded p-3 bg-white">
                                        <div class="fw-semibold mb-2">Единица @itemIndex</div>
                                        <input asp-for="Units[i].ItemIndex" type="hidden" value="@itemIndex" />
                                        <input asp-for="Units[i].SizeValue" class="form-control" type="number" min="0.001" step="0.001" data-index="@itemIndex" />
                                        <span asp-validation-for="Units[i].SizeValue" class="text-danger"></span>
                                    </div>
                                </div>
                            }
                        </div>
                        <span asp-validation-for="Units" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Сохранить приход</button>
                <a class="btn btn-outline-secondary" asp-controller="MetalWarehouse" asp-action="Receipts">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/metal-receipt-create.js" asp-append-version="true"></script>
}

<script id="materialUnitKindMap" type="application/json">@System.Text.Json.JsonSerializer.Serialize(Model.MaterialUnitKinds)</script>
<script id="receiptDebugContext" type="application/json">@System.Text.Json.JsonSerializer.Serialize(new
{
    IsPostBack = string.Equals(Context.Request.Method, "POST", StringComparison.OrdinalIgnoreCase),
    ModelStateIsValid = ViewData.ModelState.IsValid,
    Errors = ViewData.ModelState
        .Where(x => x.Value?.Errors.Count > 0)
        .SelectMany(x => x.Value!.Errors.Select(error => new
        {
            Field = x.Key,
            Message = error.ErrorMessage,
        }))
        .ToList(),
})</script>
