@model UchetNZP.Web.Models.MetalRequirementDetailsViewModel
@{
    ViewData["Title"] = $"Требование {Model.RequirementNumber}";
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-semibold">Требование @Model.RequirementNumber</h1>
    <p class="lead">Документ в режиме read-only. Фактическое списание металла не выполняется.</p>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary btn-sm" asp-controller="MetalWarehouse" asp-action="CuttingMaps">Открыть карты раскроя</a>
        <a class="btn btn-outline-primary btn-sm" asp-controller="MetalWarehouse" asp-action="RequirementPrintWarehouse" asp-route-id="@Model.Id" target="_blank">Печать для склада</a>
        <a class="btn btn-outline-primary btn-sm" asp-controller="MetalWarehouse" asp-action="RequirementPrintMaster" asp-route-id="@Model.Id" target="_blank">Печать для мастера цеха</a>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body row g-3">
        <div class="col-md-3"><div class="text-muted small">Дата</div><div class="fw-semibold">@Model.RequirementDate.ToString("dd.MM.yyyy HH:mm")</div></div>
        <div class="col-md-3"><div class="text-muted small">Статус</div><div><span class="badge bg-secondary">@Model.Status</span></div></div>
        <div class="col-md-6"><div class="text-muted small">Деталь</div><div class="fw-semibold">@Model.PartDisplay</div></div>
        <div class="col-md-3"><div class="text-muted small">Количество деталей</div><div class="fw-semibold">@Model.Quantity.ToString("0.###")</div></div>
        <div class="col-md-9">
            <div class="text-muted small">Связанный запуск</div>
            <div>
                <a asp-controller="WipLaunches" asp-action="History">@Model.WipLaunchId</a>
                @if (Model.LaunchDate.HasValue)
                {
                    <span class="text-muted">(@Model.LaunchDate.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm"))</span>
                }
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Comment))
        {
            <div class="col-12"><div class="text-muted small">Комментарий</div><div>@Model.Comment</div></div>
        }
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Итоги по документу</div>
    <div class="card-body row g-3">
        <div class="col-md-2"><div class="text-muted small">Итого, кг</div><div class="fw-semibold">@Model.Aggregates.TotalKg.ToString("0.###")</div></div>
        <div class="col-md-2"><div class="text-muted small">Итого, м</div><div class="fw-semibold">@Model.Aggregates.TotalMeters.ToString("0.###")</div></div>
        <div class="col-md-2"><div class="text-muted small">Итого, м²</div><div class="fw-semibold">@Model.Aggregates.TotalSquareMeters.ToString("0.###")</div></div>
        <div class="col-md-2"><div class="text-muted small">Прогноз отхода</div><div class="fw-semibold">@Model.Aggregates.ForecastWastePercent.ToString("0.###")%</div></div>
        <div class="col-md-2"><div class="text-muted small">Деловой остаток</div><div class="fw-semibold">@Model.Aggregates.ForecastBusinessResidual.ToString("0.###")</div></div>
        <div class="col-md-2"><div class="text-muted small">Лом</div><div class="fw-semibold">@Model.Aggregates.ForecastScrapResidual.ToString("0.###")</div></div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-light fw-semibold">Позиции требования и расчет потребности</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Материал</th>
                        <th>Артикул</th>
                        <th>Исходная заготовка</th>
                        <th>Потребность нетто</th>
                        <th>Техпотери / коэфф.</th>
                        <th>К выдаче со склада</th>
                        <th>Ожидаемый остаток (деловой / лом)</th>
                        <th>Источник расчета</th>
                        <th>Текущий остаток</th>
                        <th>Разница</th>
                        <th>Источник выбора</th>
                        <th>Обоснование / кандидаты</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.MaterialDisplay</td>
                            <td>@item.MaterialArticle</td>
                            <td>@item.SourceBlankDisplay</td>
                            <td>@item.NetRequirementQty.ToString("0.###") @item.Unit</td>
                            <td>@item.LossFactor.ToString("0.###")</td>
                            <td>@item.QtyToIssueFromStock.ToString("0.###") @item.Unit</td>
                            <td>@item.ExpectedBusinessResidual.ToString("0.###") / @item.ExpectedScrapResidual.ToString("0.###")</td>
                            <td>
                                @if (item.CuttingPlanId.HasValue)
                                {
                                    <div>
                                        <a asp-controller="MetalWarehouse" asp-action="CuttingMaps">cutting_plan @item.CuttingPlanId.Value</a>
                                    </div>
                                }
                                <div><code>@(string.IsNullOrWhiteSpace(item.CalculationFormula) ? "—" : item.CalculationFormula)</code></div>
                                @if (!string.IsNullOrWhiteSpace(item.CalculationInput))
                                {
                                    <div class="small text-muted">@item.CalculationInput</div>
                                }
                                <div class="small text-muted">Пересчёт: @item.BackCalculatedMeters.ToString("0.###") м; @item.BackCalculatedSquareMeters.ToString("0.###") м²</div>
                            </td>
                            <td>@item.StockQty.ToString("0.###") @item.Unit</td>
                            <td>
                                @if (item.IsEnough)
                                {
                                    <span class="text-success">Хватает (+@item.DifferenceQty.ToString("0.###"))</span>
                                }
                                else
                                {
                                    <span class="text-danger">Не хватает (@item.DifferenceQty.ToString("0.###"))</span>
                                }
                            </td>
                            <td><span class="badge bg-light text-dark border">@item.SelectionSource</span></td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.SelectionReason))
                                {
                                    <div>@item.SelectionReason</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.CandidateMaterials))
                                {
                                    <div class="small text-muted mt-1">@item.CandidateMaterials</div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card shadow-sm mt-4">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <span class="fw-semibold">План подбора</span>
        <div class="d-flex gap-2">
            @if (Model.RequirementPlan is null)
            {
                <form method="post" asp-controller="MetalWarehouse" asp-action="CalculateRequirementPlan" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary btn-sm">Рассчитать план</button>
                </form>
            }
            else
            {
                <form method="post" asp-controller="MetalWarehouse" asp-action="CalculateRequirementPlan" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-primary btn-sm">Пересчитать</button>
                </form>
            }
        </div>
    </div>
    <div class="card-body">
        @if (Model.RequirementPlan is null)
        {
            <div class="text-center py-4 border rounded bg-light-subtle">
                <div class="fw-semibold mb-2">План подбора еще не рассчитан</div>
                <div class="text-muted mb-3">Нажмите «Рассчитать план», чтобы сформировать электронный подбор металла без расхода склада.</div>
                <form method="post" asp-controller="MetalWarehouse" asp-action="CalculateRequirementPlan" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">Рассчитать план</button>
                </form>
            </div>
        }
        else
        {
            <div class="row g-3 mb-3">
                <div class="col-md-2"><div class="text-muted small">Требуется всего</div><div class="fw-semibold">@Model.RequirementPlan.RequiredQty.ToString("0.###") @Model.RequirementPlan.Unit</div></div>
                <div class="col-md-2"><div class="text-muted small">Подобрано</div><div class="fw-semibold">@Model.RequirementPlan.PlannedQty.ToString("0.###") @Model.RequirementPlan.Unit</div></div>
                <div class="col-md-2"><div class="text-muted small">Дефицит</div><div class="fw-semibold @(Model.RequirementPlan.DeficitQty > 0 ? "text-danger" : "text-success")">@Model.RequirementPlan.DeficitQty.ToString("0.###") @Model.RequirementPlan.Unit</div></div>
                <div class="col-md-2"><div class="text-muted small">Статус</div><div><span class="badge bg-secondary">@Model.RequirementPlan.Status</span></div></div>
                <div class="col-md-4">
                    <div class="text-muted small">Расчет</div>
                    <div class="small">
                        @Model.RequirementPlan.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm"), @Model.RequirementPlan.CreatedBy
                        @if (Model.RequirementPlan.RecalculatedAt.HasValue)
                        {
                            <span class="d-block">Пересчет: @Model.RequirementPlan.RecalculatedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm"), @(string.IsNullOrWhiteSpace(Model.RequirementPlan.RecalculatedBy) ? "—" : Model.RequirementPlan.RecalculatedBy)</span>
                        }
                    </div>
                </div>
            </div>

            @if (Model.RequirementPlan.DeficitQty > 0)
            {
                <div class="alert alert-danger py-2">
                    Не хватает: <strong>@Model.RequirementPlan.DeficitQty.ToString("0.###") @Model.RequirementPlan.Unit</strong>
                </div>
            }

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Код единицы</th>
                            <th>Размер исходный</th>
                            <th>Ед. изм.</th>
                            <th>Будет использовано</th>
                            <th>Остаток после использования</th>
                            <th>Статус</th>
                            <th>Дата прихода</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model.RequirementPlan.Items)
                        {
                            var badgeClass = line.LineStatus switch
                            {
                                "FullUse" => "bg-success",
                                "PartialCut" => "bg-warning text-dark",
                                "ReserveCandidate" => "bg-info text-dark",
                                "Deficit" => "bg-danger",
                                _ => "bg-secondary",
                            };
                            <tr>
                                <td>@line.SourceCode</td>
                                <td>@line.SourceSize.ToString("0.###")</td>
                                <td>@line.SourceUnit</td>
                                <td>@line.PlannedUseQty.ToString("0.###")</td>
                                <td>@line.RemainingAfterQty.ToString("0.###")</td>
                                <td><span class="badge @badgeClass">@line.LineStatus</span></td>
                                <td>@(line.ReceiptDate.HasValue ? line.ReceiptDate.Value.ToLocalTime().ToString("dd.MM.yyyy") : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
