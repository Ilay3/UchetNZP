@model UchetNZP.Web.Models.MetalRequirementDetailsViewModel
@{
    ViewData["Title"] = $"Требование {Model.RequirementNumber}";
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-semibold">Требование @Model.RequirementNumber</h1>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-primary btn-sm" asp-controller="MetalWarehouse" asp-action="Requirements">К списку требований</a>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body row g-3">
        <div class="col-md-3"><div class="text-muted small">Дата</div><div class="fw-semibold">@Model.RequirementDate.ToString("dd.MM.yyyy HH:mm")</div></div>
        <div class="col-md-3"><div class="text-muted small">Статус</div><div><span class="badge bg-secondary">@Model.Status</span></div></div>
        <div class="col-md-6"><div class="text-muted small">Запуск партии</div><div class="fw-semibold">@Model.WipLaunchId</div></div>
        <div class="col-md-6"><div class="text-muted small">Деталь</div><div class="fw-semibold">@Model.PartDisplay</div></div>
        <div class="col-md-3"><div class="text-muted small">Количество деталей</div><div class="fw-semibold">@Model.Quantity.ToString("0.###")</div></div>
        <div class="col-md-3"><div class="text-muted small">Материал</div><div class="fw-semibold">@Model.SourceBlankDisplay</div></div>
        @if (!string.IsNullOrWhiteSpace(Model.Comment))
        {
            <div class="col-12"><div class="text-muted small">Комментарий</div><div>@Model.Comment</div></div>
        }
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Позиции требования</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Материал</th>
                        <th>Норма на 1 шт</th>
                        <th>Ед. изм.</th>
                        <th>Требуется всего</th>
                        <th>Итого кг</th>
                        <th>Размер / примечание</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.MaterialDisplay</td>
                            <td>@item.NormPerUnit.ToString("0.###")</td>
                            <td>@item.Unit</td>
                            <td>@item.TotalRequiredQty.ToString("0.###")</td>
                            <td>@((item.TotalRequiredWeightKg ?? 0m).ToString("0.###"))</td>
                            <td>@(string.IsNullOrWhiteSpace(item.SourceBlankDisplay) ? "—" : item.SourceBlankDisplay) @if (!string.IsNullOrWhiteSpace(item.SelectionReason)) { <span class="text-muted">/ @item.SelectionReason</span> }</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="alert alert-info mb-0">
    Документ создан в электронном виде. Печать и списание пока не выполняются.
</div>
