@model UchetNZP.Web.Models.MetalRequirementDetailsViewModel
@{
    ViewData["Title"] = $"Требование {Model.RequirementNumber}";
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-semibold">Требование @Model.RequirementNumber</h1>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-primary btn-sm" asp-controller="MetalWarehouse" asp-action="Requirements">К списку требований</a>
    </div>
</div>

@if (TempData["MetalRequirementError"] is string requirementError && !string.IsNullOrWhiteSpace(requirementError))
{
    <div class="alert alert-danger">@requirementError</div>
}

<div class="card shadow-sm mb-4">
    <div class="card-body row g-3">
        <div class="col-md-3"><div class="text-muted small">Дата</div><div class="fw-semibold">@Model.RequirementDate.ToString("dd.MM.yyyy HH:mm")</div></div>
        <div class="col-md-3"><div class="text-muted small">Статус</div><div><span class="badge @(Model.Status == "Completed" ? "bg-success" : Model.Status == "Cancelled" ? "bg-danger" : Model.Status == "ReadyToIssue" ? "bg-primary" : Model.Status == "Planned" ? "bg-info text-dark" : "bg-secondary")">@Model.Status</span></div></div>
        <div class="col-md-6"><div class="text-muted small">Запуск партии</div><div class="fw-semibold">@Model.WipLaunchId</div></div>
        <div class="col-md-6"><div class="text-muted small">Деталь</div><div class="fw-semibold">@Model.PartDisplay</div></div>
        <div class="col-md-3"><div class="text-muted small">Количество деталей</div><div class="fw-semibold">@Model.Quantity.ToString("0.###")</div></div>
        <div class="col-md-3"><div class="text-muted small">Материал</div><div class="fw-semibold">@Model.MaterialDisplay</div></div>
        <div class="col-12">
            <div class="alert alert-info py-2 mb-0">Документ создан в электронном виде автоматически при сохранении запуска партии</div>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Comment))
        {
            <div class="col-12"><div class="text-muted small">Комментарий</div><div>@Model.Comment</div></div>
        }
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Документы</div>
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <div class="fw-semibold">Печатная форма доступна</div>
                <div class="text-muted small">Скачать документ можно в формате DOCX.</div>
            </div>
            <a class="btn btn-outline-primary"
               asp-controller="MetalWarehouse"
               asp-action="PrintRequirement"
               asp-route-id="@Model.Id">
                Скачать требование на склад
            </a>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Исполнение требования</div>
    <div class="card-body">
        @if (Model.ExistingIssueId.HasValue)
        {
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div>
                    <div class="text-muted small">По требованию уже оформлена выдача</div>
                    <div class="fw-semibold">Статус: @Model.ExistingIssueStatus</div>
                </div>
                <a class="btn btn-outline-primary" asp-controller="MetalWarehouse" asp-action="IssueDetails" asp-route-id="@Model.ExistingIssueId.Value">Открыть выдачу</a>
            </div>
        }
        else if (Model.CanCreateIssueFromPlan)
        {
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div>
                    <div class="text-muted small">План подбора рассчитан, дефицита нет</div>
                    <div class="fw-semibold">Можно оформить электронную выдачу со склада</div>
                </div>
                <form method="post" asp-controller="MetalWarehouse" asp-action="CreateIssueFromPlan" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">Оформить выдачу по плану</button>
                </form>
            </div>
        }
        else
        {
            <div class="alert alert-warning mb-0">
                @(string.IsNullOrWhiteSpace(Model.IssueCreationBlockedReason)
                    ? "Оформление выдачи пока недоступно."
                    : Model.IssueCreationBlockedReason)
            </div>
        }
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Позиции требования</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Материал</th>
                        <th>Норма на 1 шт</th>
                        <th>Ед. изм.</th>
                        <th>Требуется всего</th>
                        <th>Итого кг</th>
                        <th>Размер / примечание</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.MaterialDisplay</td>
                            <td>@item.NormPerUnit.ToString("0.###")</td>
                            <td>@item.Unit</td>
                            <td>@item.TotalRequiredQty.ToString("0.###")</td>
                            <td>@((item.TotalRequiredWeightKg ?? 0m).ToString("0.###"))</td>
                            <td>@(string.IsNullOrWhiteSpace(item.SourceBlankDisplay) ? "—" : item.SourceBlankDisplay) @if (!string.IsNullOrWhiteSpace(item.SelectionReason)) { <span class="text-muted">/ @item.SelectionReason</span> }</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card shadow-sm mt-4">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <span class="fw-semibold">План подбора металла</span>
        <div class="d-flex gap-2">
            @if (Model.RequirementPlan is null)
            {
                <form method="post" asp-controller="MetalWarehouse" asp-action="CalculateRequirementPlan" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary btn-sm">Рассчитать план</button>
                </form>
            }
            else
            {
                <form method="post" asp-controller="MetalWarehouse" asp-action="CalculateRequirementPlan" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-primary btn-sm">Пересчитать</button>
                </form>
            }
        </div>
    </div>
    <div class="card-body">
        @if (Model.RequirementPlan is null)
        {
            <div class="text-center py-4 border rounded bg-light-subtle">
                <div class="fw-semibold mb-2">План подбора еще не рассчитан</div>
                <div class="text-muted mb-3">Нажмите «Рассчитать план», чтобы сформировать электронный подбор металла без расхода склада.</div>
                <form method="post" asp-controller="MetalWarehouse" asp-action="CalculateRequirementPlan" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">Рассчитать план</button>
                </form>
            </div>
        }
        else
        {
            <div class="row g-3 mb-3">
                <div class="col-md-2"><div class="text-muted small">Требуется по требованию</div><div class="fw-semibold">@Model.RequirementPlan.BaseRequiredQty.ToString("0.###") @Model.RequirementPlan.Unit</div></div>
                <div class="col-md-2"><div class="text-muted small">Требуется к подбору</div><div class="fw-semibold">@Model.RequirementPlan.AdjustedRequiredQty.ToString("0.###") @Model.RequirementPlan.Unit</div></div>
                <div class="col-md-2"><div class="text-muted small">Подобрано</div><div class="fw-semibold">@Model.RequirementPlan.PlannedQty.ToString("0.###") @Model.RequirementPlan.Unit</div></div>
                <div class="col-md-2"><div class="text-muted small">Дефицит</div><div class="fw-semibold @(Model.RequirementPlan.DeficitQty > 0 ? "text-danger" : "text-success")">@Model.RequirementPlan.DeficitQty.ToString("0.###") @Model.RequirementPlan.Unit</div></div>
                <div class="col-md-2"><div class="text-muted small">Статус плана</div><div><span class="badge @(Model.RequirementPlan.Status == "HasDeficit" ? "bg-danger" : Model.RequirementPlan.Status == "Calculated" ? "bg-success" : "bg-secondary")">@Model.RequirementPlan.Status</span></div></div>
                <div class="col-md-4">
                    <div class="text-muted small">Расчет</div>
                    <div class="small">
                        @((Model.RequirementPlan.RecalculatedAt ?? Model.RequirementPlan.CreatedAt).ToLocalTime().ToString("dd.MM.yyyy HH:mm")), @(string.IsNullOrWhiteSpace(Model.RequirementPlan.RecalculatedBy) ? Model.RequirementPlan.CreatedBy : Model.RequirementPlan.RecalculatedBy)
                        @if (Model.RequirementPlan.RecalculatedAt.HasValue)
                        {
                            <span class="d-block">Пересчет: @Model.RequirementPlan.RecalculatedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm"), @(string.IsNullOrWhiteSpace(Model.RequirementPlan.RecalculatedBy) ? "—" : Model.RequirementPlan.RecalculatedBy)</span>
                        }
                    </div>
                </div>
            </div>

            @if (Model.RequirementPlan.DeficitQty > 0)
            {
                <div class="alert alert-danger py-2">
Материала недостаточно. Не хватает: <strong>@Model.RequirementPlan.DeficitQty.ToString("0.###") @Model.RequirementPlan.Unit</strong>
                </div>
            }

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Код единицы</th>
                            <th>Размер исходный</th>
                            <th>Ед. изм.</th>
                            <th>Доступно</th>
                            <th>Будет использовано</th>
                            <th>Остаток после</th>
                            <th>Статус</th>
                            <th>Дата прихода</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model.RequirementPlan.Items)
                        {
                            var badgeClass = line.LineStatus switch
                            {
                                "FullUse" => "bg-success",
                                "PartialCut" => "bg-warning text-dark",
                                "ReserveCandidate" => "bg-info text-dark",
                                "Deficit" => "bg-danger",
                                _ => "bg-secondary",
                            };
                            <tr>
                                <td>@line.SourceCode</td>
                                <td>@line.SourceSize.ToString("0.###")</td>
                                <td>@line.SourceUnit</td>
                                <td>@line.SourceSize.ToString("0.###")</td>
                                <td>@line.PlannedUseQty.ToString("0.###")</td>
                                <td>@line.RemainingAfterQty.ToString("0.###")</td>
                                <td><span class="badge @badgeClass">@line.LineStatus</span></td>
                                <td>@(line.ReceiptDate.HasValue ? line.ReceiptDate.Value.ToLocalTime().ToString("dd.MM.yyyy") : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card shadow-sm mt-4">
    <div class="card-header bg-light fw-semibold">История документа</div>
    <div class="card-body">
        @if (!Model.History.Any())
        {
            <div class="text-muted">История пока пуста.</div>
        }
        else
        {
            <ul class="list-group list-group-flush">
                @foreach (var entry in Model.History)
                {
                    <li class="list-group-item px-0">
                        <div class="d-flex justify-content-between"><span class="fw-semibold">@entry.EventType</span><span class="text-muted small">@entry.EventDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span></div>
                        <div class="small text-muted">@entry.UserName</div>
                        <div>@entry.Message</div>
                    </li>
                }
            </ul>
        }
    </div>
</div>
