@model UchetNZP.Web.Models.MetalIssueListViewModel
@{
    ViewData["Title"] = "Выдачи металла";
}

<div class="page-header mb-4">
    <h1 class="display-5 fw-semibold">Выдачи металла</h1>
    <p class="lead">Электронные документы фактической выдачи по требованиям.</p>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a class="btn btn-outline-primary" asp-controller="MetalWarehouse" asp-action="Index">На главную модуля</a>
    <a class="btn btn-outline-secondary" asp-controller="MetalWarehouse" asp-action="Requirements">Требования</a>
    <a class="btn btn-outline-secondary" asp-controller="MetalWarehouse" asp-action="Stock">Остатки</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @if (Model.Items.Count == 0)
        {
            <div class="alert alert-light border mb-0">Выдач пока нет.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle" data-app-pagination="true" data-app-page-size="25">
                    <thead class="table-light">
                        <tr>
                            <th>Номер</th>
                            <th>Дата</th>
                            <th>Требование</th>
                            <th>Деталь</th>
                            <th>Материал</th>
                            <th>Статус</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.IssueNumber</td>
                                <td>@item.IssueDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@item.RequirementNumber</td>
                                <td>@item.PartDisplay</td>
                                <td>@item.MaterialDisplay</td>
                                <td><span class="@UiDisplayText.StatusClass(item.Status)">@UiDisplayText.Status(item.Status)</span></td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-controller="MetalWarehouse" asp-action="IssueDetails" asp-route-id="@item.Id">Открыть</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
