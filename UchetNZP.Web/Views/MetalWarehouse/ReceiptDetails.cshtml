@model MetalReceiptDetailsViewModel
@{
    ViewData["Title"] = "Карточка прихода";
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-semibold">Карточка прихода @Model.ReceiptNumber</h1>
    <p class="lead mb-0">Материалы, вес, размеры и документы по поступлению металла.</p>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a class="btn btn-outline-primary" asp-controller="MetalWarehouse" asp-action="Receipts">К списку приходов</a>
    <a class="btn btn-outline-success" asp-controller="MetalWarehouse" asp-action="ReceiptDocument" asp-route-id="@Model.Id">PDF накладная</a>
    @if (Model.HasOriginalDocument)
    {
        <a class="btn btn-success" asp-controller="MetalWarehouse" asp-action="ReceiptOriginalDocument" asp-route-id="@Model.Id">Оригинал PDF</a>
    }
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Документ</div>
    <div class="card-body row g-3">
        <div class="col-md-3"><strong>Номер:</strong> @Model.ReceiptNumber</div>
        <div class="col-md-3"><strong>Дата:</strong> @Model.ReceiptDate.ToString("dd.MM.yyyy")</div>
        <div class="col-md-3"><strong>Документ поставщика:</strong> @(string.IsNullOrWhiteSpace(Model.SupplierDocumentNumber) ? "—" : Model.SupplierDocumentNumber)</div>
        <div class="col-md-3"><strong>Цена, руб/кг:</strong> @Model.PricePerKg.ToString("0.####")</div>
        <div class="col-md-6"><strong>Поставщик:</strong> @(string.IsNullOrWhiteSpace(Model.SupplierDisplay) ? "—" : Model.SupplierDisplay)</div>
        <div class="col-md-3"><strong>Сумма без НДС:</strong> @Model.AmountWithoutVat.ToString("0.00")</div>
        <div class="col-md-3"><strong>НДС @Model.VatRatePercent.ToString("0.##")%:</strong> @Model.VatAmount.ToString("0.00")</div>
        <div class="col-md-3"><strong>Всего с НДС:</strong> @Model.TotalAmountWithVat.ToString("0.00")</div>
        <div class="col-md-3"><strong>Всего штук:</strong> @Model.Quantity</div>
        <div class="col-md-3"><strong>Вес, кг:</strong> @Model.PassportWeightKg.ToString("0.###")</div>
        <div class="col-md-6"><strong>Материалы:</strong> @Model.MaterialName</div>
        <div class="col-md-6"><strong>Оригинал:</strong> @(Model.HasOriginalDocument ? Model.OriginalDocumentFileName : "не прикреплен")</div>
        <div class="col-12"><strong>Комментарий:</strong> @(string.IsNullOrWhiteSpace(Model.Comment) ? "—" : Model.Comment)</div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Что пришло</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>№</th>
                        <th>Материал</th>
                        <th>Количество</th>
                        <th>Размер</th>
                        <th>Вес, кг</th>
                        <th>Расчетный вес, кг</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in Model.Lines)
                    {
                        <tr>
                            <td>@line.LineIndex</td>
                            <td>@line.MaterialName</td>
                            <td>@line.Quantity</td>
                            <td>
                                @line.SizeSummary
                                @if (line.UsesAverageSize)
                                {
                                    <span class="badge text-bg-warning ms-2">примерно</span>
                                }
                            </td>
                            <td>@line.PassportWeightKg.ToString("0.###")</td>
                            <td title="@line.CalculatedWeightFormula">@line.CalculatedWeightKg.ToString("0.###")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-light fw-semibold">Складские единицы</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>№</th>
                        <th>Металл</th>
                        <th>Размер</th>
                        <th>Код</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ItemIndex</td>
                            <td>@item.MaterialName</td>
                            <td>
                                @item.ActualBlankSizeText
                                @if (item.IsSizeApproximate)
                                {
                                    <span class="badge text-bg-warning ms-2">примерно</span>
                                }
                            </td>
                            <td class="fw-semibold">@item.GeneratedCode</td>
                            <td class="text-nowrap">
                                <a class="btn btn-sm btn-outline-dark"
                                   asp-controller="MetalWarehouse"
                                   asp-action="ReceiptItemLabel"
                                   asp-route-id="@item.Id">
                                    Этикетка 50×50
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
