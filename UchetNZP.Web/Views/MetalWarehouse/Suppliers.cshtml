@model MetalSuppliersDirectoryViewModel
@{
    ViewData["Title"] = "Справочник поставщиков";
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-semibold">Справочник поставщиков металла</h1>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a class="btn btn-outline-primary" asp-controller="MetalWarehouse" asp-action="CreateReceipt">К приходу металла</a>
</div>

@if (TempData["MetalSuppliersSuccess"] is string success)
{
    <div class="alert alert-success">@success</div>
}

<form method="post" class="row g-3 mb-4">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="col-md-3">
        <label asp-for="Identifier" class="form-label">Код</label>
        <input asp-for="Identifier" class="form-control" placeholder="00-001828" />
    </div>
    <div class="col-md-5">
        <label asp-for="Name" class="form-label">Наименование</label>
        <input asp-for="Name" class="form-control" placeholder="АО &quot;Металлоторг&quot;" />
    </div>
    <div class="col-md-2">
        <label asp-for="Inn" class="form-label">ИНН</label>
        <input asp-for="Inn" class="form-control" placeholder="1234567890" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary w-100">Добавить</button>
    </div>
</form>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Код</th>
            <th>Наименование</th>
            <th>ИНН</th>
            <th>Статус</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var supplier in Model.Suppliers)
    {
        <tr>
            <td>@supplier.Identifier</td>
            <td>@supplier.Name</td>
            <td>@supplier.Inn</td>
            <td>@(supplier.IsActive ? "Активен" : "Отключен")</td>
        </tr>
    }
    </tbody>
</table>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
