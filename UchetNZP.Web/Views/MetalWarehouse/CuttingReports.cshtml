@model UchetNZP.Web.Models.CuttingReportPageViewModel
@{
    ViewData["Title"] = "Отчеты о резке";
}

<div class="page-header mb-4">
    <h1 class="display-6 fw-semibold">Отчет о резке</h1>
    <p class="lead mb-0">Фиксация факта раскроя: исходная заготовка, полученная продукция, деловой остаток и лом.</p>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Новый отчет</div>
    <div class="card-body">
        <form asp-action="CreateCuttingReport" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div class="col-md-4">
                <label class="form-label">План раскроя</label>
                <select class="form-select" asp-for="CreateModel.CuttingPlanId" asp-items="Model.PlanOptions"></select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Исходная заготовка</label>
                <select class="form-select" asp-for="CreateModel.SourceMetalReceiptItemId" asp-items="Model.SourceOptions"></select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Цех</label>
                <input class="form-control" asp-for="CreateModel.Workshop" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Смена</label>
                <input class="form-control" asp-for="CreateModel.Shift" />
            </div>

            <div class="col-md-3"><label class="form-label">Факт выход (длина/площадь)</label><input class="form-control" type="number" step="0.001" asp-for="CreateModel.ActualProducedSize" /></div>
            <div class="col-md-3"><label class="form-label">Факт выход, кг</label><input class="form-control" type="number" step="0.001" asp-for="CreateModel.ActualProducedMassKg" /></div>
            <div class="col-md-3"><label class="form-label">Деловой остаток</label><input class="form-control" type="number" step="0.001" asp-for="CreateModel.BusinessResidualSize" /></div>
            <div class="col-md-3"><label class="form-label">Деловой остаток, кг</label><input class="form-control" type="number" step="0.001" asp-for="CreateModel.BusinessResidualMassKg" /></div>
            <div class="col-md-3"><label class="form-label">Лом (размер)</label><input class="form-control" type="number" step="0.001" asp-for="CreateModel.ScrapSize" /></div>
            <div class="col-md-3"><label class="form-label">Лом, кг</label><input class="form-control" type="number" step="0.001" asp-for="CreateModel.ScrapMassKg" /></div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">Провести документ</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">План vs факт</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th>Документ</th><th>Дата</th><th>Требование</th><th>Материал</th><th>Источник</th><th>Цех/смена</th><th>Откл. размер</th><th>Откл. масса</th><th>Откл. отход</th></tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Reports)
                {
                    <tr>
                        <td>@item.ReportNumber</td>
                        <td>@item.ReportDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.RequirementNumber</td>
                        <td>@item.MaterialName</td>
                        <td>@item.SourceCode</td>
                        <td>@item.Workshop / @item.Shift</td>
                        <td>@item.SizeDeviation.ToString("0.###")</td>
                        <td>@item.MassDeviation.ToString("0.###")</td>
                        <td>@item.WasteDeviation.ToString("0.###")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-light fw-semibold">Аналитика отходов (цех / смена / материал)</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm table-bordered align-middle mb-0">
                <thead class="table-light"><tr><th>Цех</th><th>Смена</th><th>Материал</th><th>Документов</th><th>Ср. откл. отхода</th><th>Суммарный лом, кг</th></tr></thead>
                <tbody>
                @foreach (var row in Model.Analytics)
                {
                    <tr>
                        <td>@row.Workshop</td><td>@row.Shift</td><td>@row.MaterialName</td><td>@row.ReportsCount</td><td>@row.AvgWasteDeviation.ToString("0.###")</td><td>@row.TotalScrapMassKg.ToString("0.###")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
