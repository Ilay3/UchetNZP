@using System.Globalization
@model WarehouseIndexViewModel
@{
    ViewData["Title"] = "Склад НЗП";
}

<div class="page-header mb-4">
    <h1 class="display-5 fw-semibold">Склад НЗП</h1>
    <p class="lead mb-0">Компактный просмотр остатков и быстрое редактирование записей в одной таблице.</p>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="d-none" data-toast-message="@Model.StatusMessage" data-toast-variant="success"></div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="d-none" data-toast-message="@Model.ErrorMessage" data-toast-variant="danger"></div>
}

<div id="warehouseRoot" class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Фильтр</div>
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end" autocomplete="off">
            <div class="col-lg-7">
                <label class="form-label mb-1" for="warehouseFilterPart">Деталь</label>
                <input id="warehouseFilterPart" class="form-control" type="text" value="@Model.PartSearch" list="warehousePartOptions" placeholder="Начните вводить деталь" autocomplete="off" />
                <datalist id="warehousePartOptions"></datalist>
                <input type="hidden" id="warehouseFilterPartId" name="partId" value="@Model.SelectedPartId" />
            </div>
            <div class="col-lg-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">Показать</button>
                <a class="btn btn-secondary" asp-action="Index">Сбросить</a>
            </div>
            <div class="col-lg-2 text-lg-end">
                <span class="text-muted small">Всего: <span class="fw-semibold">@Model.TotalQuantity.ToString("0.###", CultureInfo.CurrentCulture)</span> шт</span>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-light fw-semibold">Записи склада</div>
    <div class="card-body py-3">
        @if (Model.PartGroups.Count == 0)
        {
            <div class="text-muted">Записей не найдено.</div>
        }
        else
        {
            var accordionId = "warehouseAccordion";
            var accordionIndex = 0;

            <div class="accordion warehouse-compact-accordion" id="@accordionId">
                @foreach (var partGroup in Model.PartGroups)
                {
                    var collapseId = $"warehouse-collapse-{accordionIndex}";
                    var headingId = $"warehouse-heading-{accordionIndex}";
                    var labelCount = partGroup.LabelGroups.Count;
                    var itemCount = partGroup.Items.Count;
                    accordionIndex++;

                    <div class="accordion-item">
                        <h2 class="accordion-header" id="@headingId">
                            <button class="accordion-button collapsed py-2" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                <span class="d-flex flex-wrap align-items-center gap-2 w-100 pe-2">
                                    <span class="fw-semibold">@partGroup.PartDisplay</span>
                                    <span class="badge text-bg-light">Ярлыков: @labelCount</span>
                                    <span class="badge text-bg-light">Записей: @itemCount</span>
                                    <span class="badge bg-primary ms-lg-auto">@partGroup.TotalQuantity.ToString("0.###", CultureInfo.CurrentCulture) шт</span>
                                </span>
                            </button>
                        </h2>
                        <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#@accordionId">
                            <div class="accordion-body py-2">
                                @if (labelCount > 0)
                                {
                                    <div class="table-responsive mb-3">
                                        <table class="table table-sm table-bordered align-middle mb-0 warehouse-compact-table">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Ярлык</th>
                                                    <th class="text-end">Количество</th>
                                                    <th>Добавлен</th>
                                                    <th>Обновлён</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var label in partGroup.LabelGroups)
                                                {
                                                    <tr>
                                                        <td class="fw-semibold">@(string.IsNullOrWhiteSpace(label.LabelNumber) ? "—" : label.LabelNumber)</td>
                                                        <td class="text-end">@label.TotalQuantity.ToString("0.###", CultureInfo.CurrentCulture)</td>
                                                        <td>@label.FirstAddedAt.ToLocalTime().ToString("dd.MM.yyyy", CultureInfo.CurrentCulture)</td>
                                                        <td>@(label.LastUpdatedAt.HasValue ? label.LastUpdatedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm", CultureInfo.CurrentCulture) : "—")</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }

                                @if (itemCount == 0)
                                {
                                    <div class="text-muted">Для этой детали нет записей на складе.</div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm table-hover align-middle warehouse-compact-table mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Дата</th>
                                                    <th class="text-end">Кол-во</th>
                                                    <th>Комментарий</th>
                                                    <th style="width: 430px;">Изменить</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var row in partGroup.Items)
                                                {
                                                    <tr>
                                                        <td>
                                                            @row.AddedAt.ToLocalTime().ToString("dd.MM.yyyy", CultureInfo.CurrentCulture)
                                                            <div class="small text-muted">@(row.UpdatedAt.HasValue ? $"Обновлено: {row.UpdatedAt.Value.ToLocalTime():dd.MM.yyyy HH:mm}" : "Без изменений")</div>
                                                        </td>
                                                        <td class="text-end fw-semibold">@row.Quantity.ToString("0.###", CultureInfo.CurrentCulture)</td>
                                                        <td class="small text-break">@(string.IsNullOrWhiteSpace(row.Comment) ? "—" : row.Comment)</td>
                                                        <td>
                                                            <form asp-action="Update" method="post" class="row g-1 align-items-end" data-loading-submit>
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="Id" value="@row.Id" />
                                                                <input type="hidden" name="FilterPartId" value="@Model.SelectedPartId" />
                                                                <input type="hidden" name="FilterPage" value="@Model.CurrentPage" />
                                                                <input type="hidden" name="FilterPageSize" value="@Model.PageSize" />
                                                                <div class="col-12 col-xl-3">
                                                                    <input class="form-control form-control-sm" type="number" name="Quantity" value='@row.Quantity.ToString("0.###", CultureInfo.InvariantCulture)' min="0" step="0.001" />
                                                                </div>
                                                                <div class="col-12 col-xl-3">
                                                                    <input class="form-control form-control-sm" type="date" name="AddedAt" value="@row.AddedAt.ToLocalTime().ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)" />
                                                                </div>
                                                                <div class="col-12 col-xl-4">
                                                                    <input class="form-control form-control-sm" type="text" name="Comment" maxlength="512" value="@(row.Comment ?? string.Empty)" placeholder="Комментарий" />
                                                                </div>
                                                                <div class="col-12 col-xl-2 d-grid">
                                                                    <button type="submit" class="btn btn-sm btn-primary" data-loading-label="...">OK</button>
                                                                </div>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                var isFirstPage = Model.CurrentPage <= 1;
                var isLastPage = Model.CurrentPage >= Model.TotalPages;
                var previousPage = isFirstPage ? 1 : Model.CurrentPage - 1;
                var nextPage = isLastPage ? Model.TotalPages : Model.CurrentPage + 1;

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
                    <div class="text-muted small">Страница @Model.CurrentPage из @Model.TotalPages</div>
                    <nav aria-label="Навигация по страницам склада">
                        <ul class="pagination pagination-sm justify-content-center flex-wrap mb-0">
                            <li class="page-item @(isFirstPage ? "disabled" : string.Empty)">
                                <a class="page-link" asp-action="Index" asp-route-partId="@Model.SelectedPartId" asp-route-page="@previousPage" asp-route-pageSize="@Model.PageSize">&laquo;</a>
                            </li>
                            @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                            {
                                <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : string.Empty)">
                                    <a class="page-link" asp-action="Index" asp-route-partId="@Model.SelectedPartId" asp-route-page="@pageNumber" asp-route-pageSize="@Model.PageSize">@pageNumber</a>
                                </li>
                            }
                            <li class="page-item @(isLastPage ? "disabled" : string.Empty)">
                                <a class="page-link" asp-action="Index" asp-route-partId="@Model.SelectedPartId" asp-route-page="@nextPage" asp-route-pageSize="@Model.PageSize">&raquo;</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/warehouse.js" asp-append-version="true"></script>
}
