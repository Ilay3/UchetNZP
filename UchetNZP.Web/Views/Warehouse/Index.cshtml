@using System.Globalization
@using System.Linq
@model WarehouseIndexViewModel
@{
    ViewData["Title"] = "Склад СГДУ";

    var totalPages = Model.TotalPages == 0 ? 1 : Model.TotalPages;
    var firstItemNumber = Model.Items.Count == 0 ? 0 : ((Model.CurrentPage - 1) * Model.PageSize) + 1;
    var lastItemNumber = Model.Items.Count == 0 ? 0 : firstItemNumber + Model.Items.Count - 1;
    var pageStart = Math.Max(1, Model.CurrentPage - 2);
    var pageEnd = Math.Min(totalPages, Model.CurrentPage + 2);
    var isReceiptTab = Model.MovementFilter == "receipts";
    var isIssueTab = Model.MovementFilter == "issues";
    var isAllTab = !isReceiptTab && !isIssueTab;
}

<div id="warehouseRoot" class="warehouse-page" data-auto-print-control-card-url="@Model.AutoPrintControlCardUrl">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="d-none" data-toast-message="@Model.StatusMessage" data-toast-variant="success"></div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="d-none" data-toast-message="@Model.ErrorMessage" data-toast-variant="danger"></div>
    }

    <section class="warehouse-hero">
        <div>
            <div class="warehouse-hero__label">Склад СГДУ</div>
            <h1>Готовые детали и сборочные узлы</h1>
            <p>Приход после НЗП, ручной приход, расход на СИП и контроль текущих остатков в одной рабочей раскладке.</p>
        </div>
        <div class="warehouse-hero__meta">
            <span>@DateTime.Today.ToString("dd.MM.yyyy", CultureInfo.CurrentCulture)</span>
            <span>@Model.BalanceGroupCount.ToString("0", CultureInfo.CurrentCulture) позиций</span>
        </div>
    </section>

    <section class="warehouse-kpi-grid" aria-label="Показатели склада">
        <div class="warehouse-kpi warehouse-kpi--primary">
            <div class="warehouse-kpi__label">Текущий остаток</div>
            <div class="warehouse-kpi__value">@FormatQuantity(Model.TotalQuantity)</div>
            <div class="warehouse-kpi__note">шт. по выбранному фильтру</div>
        </div>
        <div class="warehouse-kpi">
            <div class="warehouse-kpi__label">Приход</div>
            <div class="warehouse-kpi__value">@FormatQuantity(Model.ReceiptQuantity)</div>
            <div class="warehouse-kpi__note">@Model.ReceiptMovementCount записей</div>
        </div>
        <div class="warehouse-kpi">
            <div class="warehouse-kpi__label">Расход</div>
            <div class="warehouse-kpi__value">@FormatQuantity(Model.IssueQuantity)</div>
            <div class="warehouse-kpi__note">@Model.IssueMovementCount записей</div>
        </div>
        <div class="warehouse-kpi">
            <div class="warehouse-kpi__label">Источники</div>
            <div class="warehouse-kpi__split">
                <span>Авто: @Model.AutomaticReceiptCount</span>
                <span>Ручн.: @(Model.ManualReceiptCount + Model.ManualIssueCount)</span>
            </div>
            <div class="warehouse-kpi__note">по журналу движения</div>
        </div>
    </section>

    <section class="warehouse-panel warehouse-ops-panel">
        <div class="warehouse-panel__header">
            <div>
                <h2>Операции склада</h2>
                <p>Приходы и расходы разделены на самостоятельные вкладки.</p>
            </div>
        </div>

        <ul class="nav nav-pills warehouse-tabs" id="warehouseOperationTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="warehouseReceiptsTab" data-bs-toggle="pill" data-bs-target="#warehouseReceiptsPane" type="button" role="tab" aria-controls="warehouseReceiptsPane" aria-selected="true">
                    <i class="bi bi-box-arrow-in-down" aria-hidden="true"></i>
                    Приход
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="warehouseIssuesTab" data-bs-toggle="pill" data-bs-target="#warehouseIssuesPane" type="button" role="tab" aria-controls="warehouseIssuesPane" aria-selected="false">
                    <i class="bi bi-box-arrow-up" aria-hidden="true"></i>
                    Расход
                </button>
            </li>
        </ul>

        <div class="tab-content warehouse-ops-content" id="warehouseOperationTabsContent">
            <div class="tab-pane fade show active" id="warehouseReceiptsPane" role="tabpanel" aria-labelledby="warehouseReceiptsTab" tabindex="0">
                <div class="warehouse-form-grid">
                    <form asp-action="ManualReceipt" method="post" class="warehouse-form" autocomplete="off" data-loading-submit>
                        @Html.AntiForgeryToken()
                        <div class="warehouse-form__title">
                            <span class="warehouse-form__icon warehouse-form__icon--receipt"><i class="bi bi-nut" aria-hidden="true"></i></span>
                            <div>
                                <h3>Приход деталей</h3>
                                <p>Готовая деталь с картой контроля</p>
                            </div>
                        </div>
                        <div class="row g-3 align-items-end">
                            <div class="col-lg-8">
                                <label class="form-label" for="warehouseManualPart">Деталь</label>
                                <input id="warehouseManualPart" class="form-control" type="text" list="warehouseManualPartOptions" placeholder="Наименование или чертеж" autocomplete="off" />
                                <datalist id="warehouseManualPartOptions"></datalist>
                                <input type="hidden" id="warehouseManualPartId" name="PartId" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualLabel">Ярлык</label>
                                <input id="warehouseManualLabel" class="form-control" type="text" name="LabelNumber" list="warehouseManualLabelOptions" maxlength="32" placeholder="Выберите или введите новый" autocomplete="off" />
                                <datalist id="warehouseManualLabelOptions"></datalist>
                                <input type="hidden" id="warehouseManualLabelId" name="WipLabelId" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualQuantity">Количество</label>
                                <input id="warehouseManualQuantity" class="form-control" type="number" name="Quantity" min="0.001" step="0.001" placeholder="10" required />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualDate">Дата</label>
                                <input id="warehouseManualDate" class="form-control" type="date" name="ReceiptDate" value="@Model.ManualReceipt.ReceiptDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)" required />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualDocument">Документ</label>
                                <input id="warehouseManualDocument" class="form-control" type="text" name="DocumentNumber" maxlength="64" placeholder="РУЧ-20260512-001" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualCard">Карта контроля</label>
                                <input id="warehouseManualCard" class="form-control" type="text" name="ControlCardNumber" maxlength="64" placeholder="Номер документа" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualController">Контролер</label>
                                <input id="warehouseManualController" class="form-control" type="text" name="ControllerName" maxlength="128" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualMaster">Мастер</label>
                                <input id="warehouseManualMaster" class="form-control" type="text" name="MasterName" maxlength="128" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualAccepted">Принял</label>
                                <input id="warehouseManualAccepted" class="form-control" type="text" name="AcceptedByName" maxlength="128" />
                            </div>
                            <div class="col-12">
                                <label class="form-label" for="warehouseManualComment">Комментарий</label>
                                <input id="warehouseManualComment" class="form-control" type="text" name="Comment" maxlength="512" />
                            </div>
                            <div class="col-lg-7">
                                <div class="form-check warehouse-check">
                                    <input id="warehouseManualPrint" class="form-check-input" type="checkbox" name="PrintControlCard" value="true" checked />
                                    <input type="hidden" name="PrintControlCard" value="false" />
                                    <label class="form-check-label" for="warehouseManualPrint">Открыть карту контроля</label>
                                </div>
                            </div>
                            <div class="col-lg-5 d-grid">
                                <button type="submit" class="btn btn-primary" data-loading-label="Оформляем...">
                                    <i class="bi bi-check2-circle" aria-hidden="true"></i>
                                    Оформить приход
                                </button>
                            </div>
                        </div>
                    </form>

                    <form asp-action="ManualAssemblyUnitReceipt" method="post" class="warehouse-form" autocomplete="off" data-loading-submit>
                        @Html.AntiForgeryToken()
                        <div class="warehouse-form__title">
                            <span class="warehouse-form__icon warehouse-form__icon--receipt"><i class="bi bi-boxes" aria-hidden="true"></i></span>
                            <div>
                                <h3>Приход сборочных узлов</h3>
                                <p>Локальный узел склада СГДУ</p>
                            </div>
                        </div>
                        <div class="row g-3 align-items-end">
                            <div class="col-lg-8">
                                <label class="form-label" for="warehouseManualAssemblyUnit">Сборочный узел</label>
                                <input id="warehouseManualAssemblyUnit" class="form-control" type="text" name="AssemblyUnitName" list="warehouseManualAssemblyUnitOptions" maxlength="256" placeholder="Наименование узла" autocomplete="off" required />
                                <datalist id="warehouseManualAssemblyUnitOptions"></datalist>
                                <input type="hidden" id="warehouseManualAssemblyUnitId" name="AssemblyUnitId" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualAssemblyLabel">Ярлык узла</label>
                                <input id="warehouseManualAssemblyLabel" class="form-control" type="text" name="LabelNumber" list="warehouseManualAssemblyLabelOptions" maxlength="32" placeholder="Выберите или введите новый" autocomplete="off" />
                                <datalist id="warehouseManualAssemblyLabelOptions"></datalist>
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualAssemblyQuantity">Количество</label>
                                <input id="warehouseManualAssemblyQuantity" class="form-control" type="number" name="Quantity" min="0.001" step="0.001" placeholder="10" required />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualAssemblyDate">Дата</label>
                                <input id="warehouseManualAssemblyDate" class="form-control" type="date" name="ReceiptDate" value="@Model.AssemblyUnitReceipt.ReceiptDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)" required />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualAssemblyDocument">Документ</label>
                                <input id="warehouseManualAssemblyDocument" class="form-control" type="text" name="DocumentNumber" maxlength="64" placeholder="РУЧ-20260512-001" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualAssemblyCard">Карта контроля</label>
                                <input id="warehouseManualAssemblyCard" class="form-control" type="text" name="ControlCardNumber" maxlength="64" placeholder="Номер документа" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualAssemblyController">Контролер</label>
                                <input id="warehouseManualAssemblyController" class="form-control" type="text" name="ControllerName" maxlength="128" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualAssemblyMaster">Мастер</label>
                                <input id="warehouseManualAssemblyMaster" class="form-control" type="text" name="MasterName" maxlength="128" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseManualAssemblyAccepted">Принял</label>
                                <input id="warehouseManualAssemblyAccepted" class="form-control" type="text" name="AcceptedByName" maxlength="128" />
                            </div>
                            <div class="col-12">
                                <label class="form-label" for="warehouseManualAssemblyComment">Комментарий</label>
                                <input id="warehouseManualAssemblyComment" class="form-control" type="text" name="Comment" maxlength="512" />
                            </div>
                            <div class="col-lg-7">
                                <div class="form-check warehouse-check">
                                    <input id="warehouseManualAssemblyPrint" class="form-check-input" type="checkbox" name="PrintControlCard" value="true" checked />
                                    <input type="hidden" name="PrintControlCard" value="false" />
                                    <label class="form-check-label" for="warehouseManualAssemblyPrint">Открыть карту контроля</label>
                                </div>
                            </div>
                            <div class="col-lg-5 d-grid">
                                <button type="submit" class="btn btn-primary" data-loading-label="Оформляем...">
                                    <i class="bi bi-check2-circle" aria-hidden="true"></i>
                                    Оформить приход
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="tab-pane fade" id="warehouseIssuesPane" role="tabpanel" aria-labelledby="warehouseIssuesTab" tabindex="0">
                <div class="warehouse-form-grid">
                    <form asp-action="ManualIssue" method="post" class="warehouse-form warehouse-form--issue" autocomplete="off" data-loading-submit>
                        @Html.AntiForgeryToken()
                        <div class="warehouse-form__title">
                            <span class="warehouse-form__icon warehouse-form__icon--issue"><i class="bi bi-arrow-up-right-square" aria-hidden="true"></i></span>
                            <div>
                                <h3>Расход деталей</h3>
                                <p>Выдача готовой детали на СИП</p>
                            </div>
                        </div>
                        <div class="row g-3 align-items-end">
                            <div class="col-lg-8">
                                <label class="form-label" for="warehouseIssuePart">Деталь</label>
                                <input id="warehouseIssuePart" class="form-control" type="text" list="warehouseIssuePartOptions" placeholder="Наименование или чертеж" autocomplete="off" />
                                <datalist id="warehouseIssuePartOptions"></datalist>
                                <input type="hidden" id="warehouseIssuePartId" name="PartId" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseIssueLabel">Ярлык</label>
                                <input id="warehouseIssueLabel" class="form-control" type="text" name="LabelNumber" list="warehouseIssueLabelOptions" maxlength="32" placeholder="Ярлык с остатком" autocomplete="off" />
                                <datalist id="warehouseIssueLabelOptions"></datalist>
                                <input type="hidden" id="warehouseIssueLabelId" name="WipLabelId" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseIssueQuantity">Количество</label>
                                <input id="warehouseIssueQuantity" class="form-control" type="number" name="Quantity" min="0.001" step="0.001" placeholder="5" required />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseIssueDate">Дата</label>
                                <input id="warehouseIssueDate" class="form-control" type="date" name="IssueDate" value="@Model.ManualIssue.IssueDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)" required />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseIssueDocument">Документ</label>
                                <input id="warehouseIssueDocument" class="form-control" type="text" name="DocumentNumber" maxlength="64" placeholder="РАСХ-20260512-001" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseIssueAccepted">Получатель</label>
                                <input id="warehouseIssueAccepted" class="form-control" type="text" name="AcceptedByName" maxlength="128" value="@Model.ManualIssue.AcceptedByName" />
                            </div>
                            <div class="col-lg-8">
                                <label class="form-label" for="warehouseIssueComment">Комментарий</label>
                                <input id="warehouseIssueComment" class="form-control" type="text" name="Comment" maxlength="512" />
                            </div>
                            <div class="col-lg-4 d-grid">
                                <button type="submit" class="btn btn-outline-danger" data-loading-label="Списываем...">
                                    <i class="bi bi-dash-circle" aria-hidden="true"></i>
                                    Оформить расход
                                </button>
                            </div>
                        </div>
                    </form>

                    <form asp-action="ManualAssemblyUnitIssue" method="post" class="warehouse-form warehouse-form--issue" autocomplete="off" data-loading-submit>
                        @Html.AntiForgeryToken()
                        <div class="warehouse-form__title">
                            <span class="warehouse-form__icon warehouse-form__icon--issue"><i class="bi bi-box-arrow-up" aria-hidden="true"></i></span>
                            <div>
                                <h3>Расход сборочных узлов</h3>
                                <p>Выдача узла при наличии остатка</p>
                            </div>
                        </div>
                        <div class="row g-3 align-items-end">
                            <div class="col-lg-8">
                                <label class="form-label" for="warehouseIssueAssemblyUnit">Сборочный узел</label>
                                <input id="warehouseIssueAssemblyUnit" class="form-control" type="text" name="AssemblyUnitName" list="warehouseIssueAssemblyUnitOptions" maxlength="256" placeholder="Наименование узла" autocomplete="off" required />
                                <datalist id="warehouseIssueAssemblyUnitOptions"></datalist>
                                <input type="hidden" id="warehouseIssueAssemblyUnitId" name="AssemblyUnitId" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseIssueAssemblyLabel">Ярлык узла</label>
                                <input id="warehouseIssueAssemblyLabel" class="form-control" type="text" name="LabelNumber" list="warehouseIssueAssemblyLabelOptions" maxlength="32" placeholder="Ярлык с остатком" autocomplete="off" />
                                <datalist id="warehouseIssueAssemblyLabelOptions"></datalist>
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseIssueAssemblyQuantity">Количество</label>
                                <input id="warehouseIssueAssemblyQuantity" class="form-control" type="number" name="Quantity" min="0.001" step="0.001" placeholder="5" required />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseIssueAssemblyDate">Дата</label>
                                <input id="warehouseIssueAssemblyDate" class="form-control" type="date" name="IssueDate" value="@Model.AssemblyUnitIssue.IssueDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)" required />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseIssueAssemblyDocument">Документ</label>
                                <input id="warehouseIssueAssemblyDocument" class="form-control" type="text" name="DocumentNumber" maxlength="64" placeholder="РАСХ-20260512-001" />
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label" for="warehouseIssueAssemblyAccepted">Получатель</label>
                                <input id="warehouseIssueAssemblyAccepted" class="form-control" type="text" name="AcceptedByName" maxlength="128" value="@Model.AssemblyUnitIssue.AcceptedByName" />
                            </div>
                            <div class="col-lg-8">
                                <label class="form-label" for="warehouseIssueAssemblyComment">Комментарий</label>
                                <input id="warehouseIssueAssemblyComment" class="form-control" type="text" name="Comment" maxlength="512" />
                            </div>
                            <div class="col-lg-4 d-grid">
                                <button type="submit" class="btn btn-outline-danger" data-loading-label="Списываем...">
                                    <i class="bi bi-dash-circle" aria-hidden="true"></i>
                                    Оформить расход
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <section id="warehouseFilter" class="warehouse-panel warehouse-filter-panel">
        <form method="get" class="warehouse-filter" autocomplete="off">
            <input type="hidden" name="movement" value="@Model.MovementFilter" />
            <div class="warehouse-filter__search">
                <label class="form-label" for="warehouseFilterPart">Номенклатура, деталь, узел или документ</label>
                <input id="warehouseFilterPart" class="form-control" type="text" name="partSearch" value="@Model.PartSearch" list="warehousePartOptions" placeholder="Начните вводить наименование или чертеж" autocomplete="off" />
                <datalist id="warehousePartOptions"></datalist>
                <input type="hidden" id="warehouseFilterPartId" name="partId" value="@Model.SelectedPartId" />
            </div>
            <div class="warehouse-filter__size">
                <label class="form-label" for="warehousePageSize">Строк</label>
                <select id="warehousePageSize" class="form-select" name="pageSize">
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="20" selected="@(Model.PageSize == 20)">20</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    <option value="100" selected="@(Model.PageSize == 100)">100</option>
                </select>
            </div>
            <div class="warehouse-filter__actions">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-funnel" aria-hidden="true"></i>
                    Показать
                </button>
                <a class="btn btn-secondary" asp-action="Index">
                    <i class="bi bi-x-circle" aria-hidden="true"></i>
                    Сбросить
                </a>
            </div>
        </form>
    </section>

    <section id="warehouseBalances" class="warehouse-panel">
        <div class="warehouse-panel__header">
            <div>
                <h2>Текущие остатки</h2>
                <p>@Model.BalanceGroupCount позиций по выбранному фильтру</p>
            </div>
            <div class="warehouse-panel__summary">
                <span>@FormatQuantity(Model.TotalQuantity) шт.</span>
            </div>
        </div>

        @if (Model.PartGroups.Count == 0)
        {
            <div class="warehouse-empty">Остатков по выбранному фильтру нет.</div>
        }
        else
        {
            var balanceIndex = 0;
            <div class="table-responsive warehouse-table-wrap">
                <table class="table warehouse-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Номенклатура</th>
                            <th class="text-end">Остаток</th>
                            <th class="text-end">Приход</th>
                            <th class="text-end">Расход</th>
                            <th>Последнее движение</th>
                            <th>Ярлыки</th>
                            <th class="warehouse-action-cell">Деталь</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in Model.PartGroups)
                        {
                            var detailId = $"warehouseBalanceDetail{balanceIndex++}";
                            var balanceClass = group.TotalQuantity < 0 ? "warehouse-qty--issue" : group.TotalQuantity > 0 ? "warehouse-qty--receipt" : "warehouse-qty--neutral";
                            <tr>
                                <td>
                                    <div class="warehouse-main-cell">@group.ItemDisplay</div>
                                    <div class="warehouse-sub-cell">@group.ItemKindTitle · @group.MovementCount движ.</div>
                                </td>
                                <td class="text-end"><span class="warehouse-qty @balanceClass">@FormatQuantity(group.TotalQuantity)</span></td>
                                <td class="text-end">@FormatQuantity(group.ReceiptQuantity)</td>
                                <td class="text-end">@FormatQuantity(group.IssueQuantity)</td>
                                <td>
                                    <div>@group.LastMovementAt.ToLocalTime().ToString("dd.MM.yyyy", CultureInfo.CurrentCulture)</div>
                                    <div class="warehouse-sub-cell">@group.LastMovementTitle · @group.LastSourceTitle</div>
                                </td>
                                <td>
                                    @if (group.LabelGroups.Count == 0)
                                    {
                                        <span class="warehouse-sub-cell">—</span>
                                    }
                                    else
                                    {
                                        foreach (var label in group.LabelGroups.Take(4))
                                        {
                                            <span class="warehouse-label-chip">@label.LabelNumber · @FormatQuantity(label.TotalQuantity)</span>
                                        }
                                        @if (group.LabelGroups.Count > 4)
                                        {
                                            <span class="warehouse-label-chip">+@(group.LabelGroups.Count - 4)</span>
                                        }
                                    }
                                </td>
                                <td class="warehouse-action-cell">
                                    <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#@detailId" aria-expanded="false" aria-controls="@detailId">
                                        <i class="bi bi-list-ul" aria-hidden="true"></i>
                                        Движения
                                    </button>
                                </td>
                            </tr>
                            <tr class="collapse warehouse-detail-row" id="@detailId">
                                <td colspan="7">
                                    <div class="warehouse-detail-grid">
                                        @foreach (var movementRow in group.Items)
                                        {
                                            var documentNumber = string.IsNullOrWhiteSpace(movementRow.DocumentNumber) ? "—" : movementRow.DocumentNumber;
                                            var cardNumber = string.IsNullOrWhiteSpace(movementRow.ControlCardNumber) ? "—" : movementRow.ControlCardNumber;
                                            <div class="warehouse-detail-card">
                                                <div class="warehouse-detail-card__top">
                                                    <span class="warehouse-status @(movementRow.MovementType == "Issue" ? "warehouse-status--issue" : "warehouse-status--receipt")">@movementRow.MovementTitle</span>
                                                    <strong>@FormatQuantity(movementRow.Quantity) шт.</strong>
                                                </div>
                                                <dl>
                                                    <div><dt>Дата</dt><dd>@movementRow.AddedAt.ToLocalTime().ToString("dd.MM.yyyy", CultureInfo.CurrentCulture)</dd></div>
                                                    <div><dt>Источник</dt><dd>@movementRow.SourceTitle</dd></div>
                                                    <div><dt>Документ</dt><dd>@documentNumber</dd></div>
                                                    <div><dt>Карта</dt><dd>@cardNumber</dd></div>
                                                </dl>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section id="warehouseJournal" class="warehouse-panel">
        <div class="warehouse-panel__header warehouse-panel__header--stack">
            <div>
                <h2>Журнал движений</h2>
                <p>Строки @firstItemNumber-@lastItemNumber из @CurrentMovementCount(Model) · страница @Model.CurrentPage из @totalPages</p>
            </div>
            <nav class="warehouse-movement-tabs" aria-label="Фильтр движения склада">
                <a class="warehouse-movement-tabs__item @(isAllTab ? "active" : string.Empty)" asp-action="Index" asp-route-partId="@Model.SelectedPartId" asp-route-partSearch="@Model.PartSearch" asp-route-movement="all" asp-route-page="1" asp-route-pageSize="@Model.PageSize">
                    Все <span>@Model.TotalMovementCount</span>
                </a>
                <a class="warehouse-movement-tabs__item @(isReceiptTab ? "active" : string.Empty)" asp-action="Index" asp-route-partId="@Model.SelectedPartId" asp-route-partSearch="@Model.PartSearch" asp-route-movement="receipts" asp-route-page="1" asp-route-pageSize="@Model.PageSize">
                    Приходы <span>@Model.ReceiptMovementCount</span>
                </a>
                <a class="warehouse-movement-tabs__item @(isIssueTab ? "active" : string.Empty)" asp-action="Index" asp-route-partId="@Model.SelectedPartId" asp-route-partSearch="@Model.PartSearch" asp-route-movement="issues" asp-route-page="1" asp-route-pageSize="@Model.PageSize">
                    Расходы <span>@Model.IssueMovementCount</span>
                </a>
            </nav>
        </div>

        @if (Model.Items.Count == 0)
        {
            <div class="warehouse-empty">Записей движения не найдено.</div>
        }
        else
        {
            var rowIndex = 0;
            <div class="table-responsive warehouse-table-wrap">
                <table class="table warehouse-table warehouse-movement-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Тип</th>
                            <th>Номенклатура</th>
                            <th>Документ</th>
                            <th class="text-end">Кол-во</th>
                            <th>Дата</th>
                            <th>Ярлыки</th>
                            <th class="warehouse-action-cell">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Items)
                        {
                            var detailId = $"warehouseMovementDetail{rowIndex++}";
                            var controlCardNumber = string.IsNullOrWhiteSpace(row.ControlCardNumber) ? "—" : row.ControlCardNumber;
                            var documentNumber = string.IsNullOrWhiteSpace(row.DocumentNumber) ? "—" : row.DocumentNumber;
                            <tr>
                                <td>
                                    <span class="warehouse-status @(row.MovementType == "Issue" ? "warehouse-status--issue" : "warehouse-status--receipt")">@row.MovementTitle</span>
                                    <div class="warehouse-sub-cell">@row.SourceTitle</div>
                                </td>
                                <td>
                                    <div class="warehouse-main-cell">@row.ItemDisplay</div>
                                    <div class="warehouse-sub-cell">@row.ItemKindTitle</div>
                                    @if (!string.IsNullOrWhiteSpace(row.Comment))
                                    {
                                        <div class="warehouse-sub-cell text-break">@row.Comment</div>
                                    }
                                </td>
                                <td>
                                    <div>@documentNumber</div>
                                    <div class="warehouse-sub-cell">Карта: @controlCardNumber</div>
                                </td>
                                <td class="text-end"><span class="warehouse-qty @(row.MovementType == "Issue" ? "warehouse-qty--issue" : "warehouse-qty--receipt")">@FormatQuantity(row.Quantity)</span></td>
                                <td>
                                    @row.AddedAt.ToLocalTime().ToString("dd.MM.yyyy", CultureInfo.CurrentCulture)
                                    <div class="warehouse-sub-cell">@(row.UpdatedAt.HasValue ? $"Обновлено: {row.UpdatedAt.Value.ToLocalTime():dd.MM.yyyy HH:mm}" : "Без изменений")</div>
                                </td>
                                <td>
                                    @if (row.LabelRows.Count == 0)
                                    {
                                        <span class="warehouse-sub-cell">—</span>
                                    }
                                    else
                                    {
                                        foreach (var label in row.LabelRows)
                                        {
                                            <span class="warehouse-label-chip">@label.LabelNumber · @FormatQuantity(label.Quantity)</span>
                                        }
                                    }
                                </td>
                                <td class="warehouse-action-cell">
                                    <div class="warehouse-row-actions">
                                        @if (row.MovementType != "Issue")
                                        {
                                            <a class="btn btn-sm btn-outline-primary" asp-action="ControlCard" asp-route-id="@row.Id" target="_blank" rel="noopener">
                                                <i class="bi bi-printer" aria-hidden="true"></i>
                                                Карта
                                            </a>
                                        }
                                        <button class="btn btn-sm btn-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#@detailId" aria-expanded="false" aria-controls="@detailId">
                                            <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                            Деталь
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <tr class="collapse warehouse-detail-row" id="@detailId">
                                <td colspan="7">
                                    <form asp-action="Update" method="post" class="warehouse-edit-form" data-loading-submit>
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Id" value="@row.Id" />
                                        <input type="hidden" name="FilterPartId" value="@Model.SelectedPartId" />
                                        <input type="hidden" name="FilterPartSearch" value="@Model.PartSearch" />
                                        <input type="hidden" name="FilterMovement" value="@Model.MovementFilter" />
                                        <input type="hidden" name="FilterPage" value="@Model.CurrentPage" />
                                        <input type="hidden" name="FilterPageSize" value="@Model.PageSize" />
                                        <div class="warehouse-edit-form__summary">
                                            <div>
                                                <strong>@row.ItemDisplay</strong>
                                                <span>@row.ItemKindTitle · @row.SourceTitle</span>
                                            </div>
                                            @if (row.TransferId.HasValue)
                                            {
                                                <span>Передача НЗП: @(row.TransferId.Value.ToString("N")[..8])</span>
                                            }
                                        </div>
                                        <div class="row g-2 align-items-end">
                                            <div class="col-6 col-lg-2">
                                                <label class="form-label" for="quantity-@row.Id">Количество</label>
                                                <input id="quantity-@row.Id" class="form-control form-control-sm" type="number" name="Quantity" value='@row.Quantity.ToString("0.###", CultureInfo.InvariantCulture)' min="0" step="0.001" />
                                            </div>
                                            <div class="col-6 col-lg-2">
                                                <label class="form-label" for="date-@row.Id">Дата</label>
                                                <input id="date-@row.Id" class="form-control form-control-sm" type="date" name="AddedAt" value="@row.AddedAt.ToLocalTime().ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)" />
                                            </div>
                                            <div class="col-6 col-lg-2">
                                                <label class="form-label" for="document-@row.Id">Документ</label>
                                                <input id="document-@row.Id" class="form-control form-control-sm" type="text" name="DocumentNumber" maxlength="64" value="@(row.DocumentNumber ?? string.Empty)" />
                                            </div>
                                            <div class="col-6 col-lg-2">
                                                <label class="form-label" for="card-@row.Id">Карта</label>
                                                <input id="card-@row.Id" class="form-control form-control-sm" type="text" name="ControlCardNumber" maxlength="64" value="@(row.ControlCardNumber ?? string.Empty)" />
                                            </div>
                                            <div class="col-12 col-lg-4">
                                                <label class="form-label" for="comment-@row.Id">Комментарий</label>
                                                <input id="comment-@row.Id" class="form-control form-control-sm" type="text" name="Comment" maxlength="512" value="@(row.Comment ?? string.Empty)" />
                                            </div>
                                            <div class="col-6 col-lg-3">
                                                <label class="form-label" for="controller-@row.Id">Контролер</label>
                                                <input id="controller-@row.Id" class="form-control form-control-sm" type="text" name="ControllerName" maxlength="128" value="@(row.ControllerName ?? string.Empty)" />
                                            </div>
                                            <div class="col-6 col-lg-3">
                                                <label class="form-label" for="master-@row.Id">Мастер</label>
                                                <input id="master-@row.Id" class="form-control form-control-sm" type="text" name="MasterName" maxlength="128" value="@(row.MasterName ?? string.Empty)" />
                                            </div>
                                            <div class="col-6 col-lg-3">
                                                <label class="form-label" for="accepted-@row.Id">Принял/получил</label>
                                                <input id="accepted-@row.Id" class="form-control form-control-sm" type="text" name="AcceptedByName" maxlength="128" value="@(row.AcceptedByName ?? string.Empty)" />
                                            </div>
                                            <div class="col-6 col-lg-3 d-grid">
                                                <button type="submit" class="btn btn-sm btn-primary" data-loading-label="Сохраняем...">
                                                    <i class="bi bi-save" aria-hidden="true"></i>
                                                    Сохранить
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                var isFirstPage = Model.CurrentPage <= 1;
                var isLastPage = Model.CurrentPage >= Model.TotalPages;
                var previousPage = isFirstPage ? 1 : Model.CurrentPage - 1;
                var nextPage = isLastPage ? Model.TotalPages : Model.CurrentPage + 1;

                <div class="warehouse-pagination">
                    <div class="warehouse-sub-cell">Страница @Model.CurrentPage из @Model.TotalPages</div>
                    <nav aria-label="Навигация по складу">
                        <ul class="pagination pagination-sm justify-content-center flex-wrap mb-0">
                            <li class="page-item @(isFirstPage ? "disabled" : string.Empty)">
                                <a class="page-link" asp-action="Index" asp-route-partId="@Model.SelectedPartId" asp-route-partSearch="@Model.PartSearch" asp-route-movement="@Model.MovementFilter" asp-route-page="@previousPage" asp-route-pageSize="@Model.PageSize" aria-label="Предыдущая">
                                    <i class="bi bi-chevron-left" aria-hidden="true"></i>
                                </a>
                            </li>
                            @if (pageStart > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-partId="@Model.SelectedPartId" asp-route-partSearch="@Model.PartSearch" asp-route-movement="@Model.MovementFilter" asp-route-page="1" asp-route-pageSize="@Model.PageSize">1</a>
                                </li>
                                @if (pageStart > 2)
                                {
                                    <li class="page-item disabled"><span class="page-link">…</span></li>
                                }
                            }
                            @for (var pageNumber = pageStart; pageNumber <= pageEnd; pageNumber++)
                            {
                                <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : string.Empty)">
                                    <a class="page-link" asp-action="Index" asp-route-partId="@Model.SelectedPartId" asp-route-partSearch="@Model.PartSearch" asp-route-movement="@Model.MovementFilter" asp-route-page="@pageNumber" asp-route-pageSize="@Model.PageSize">@pageNumber</a>
                                </li>
                            }
                            @if (pageEnd < Model.TotalPages)
                            {
                                @if (pageEnd < Model.TotalPages - 1)
                                {
                                    <li class="page-item disabled"><span class="page-link">…</span></li>
                                }
                                <li class="page-item">
                                    <a class="page-link" asp-action="Index" asp-route-partId="@Model.SelectedPartId" asp-route-partSearch="@Model.PartSearch" asp-route-movement="@Model.MovementFilter" asp-route-page="@Model.TotalPages" asp-route-pageSize="@Model.PageSize">@Model.TotalPages</a>
                                </li>
                            }
                            <li class="page-item @(isLastPage ? "disabled" : string.Empty)">
                                <a class="page-link" asp-action="Index" asp-route-partId="@Model.SelectedPartId" asp-route-partSearch="@Model.PartSearch" asp-route-movement="@Model.MovementFilter" asp-route-page="@nextPage" asp-route-pageSize="@Model.PageSize" aria-label="Следующая">
                                    <i class="bi bi-chevron-right" aria-hidden="true"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </section>
</div>

@section Scripts {
    <script src="~/js/warehouse.js" asp-append-version="true"></script>
}

@functions {
    private static string FormatQuantity(decimal value)
    {
        return value.ToString("0.###", CultureInfo.CurrentCulture);
    }

    private static int CurrentMovementCount(WarehouseIndexViewModel model)
    {
        return model.MovementFilter switch
        {
            "receipts" => model.ReceiptMovementCount,
            "issues" => model.IssueMovementCount,
            _ => model.TotalMovementCount,
        };
    }
}
