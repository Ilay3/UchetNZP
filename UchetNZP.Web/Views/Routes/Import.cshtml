@using UchetNZP.Shared
@{
    ViewData["Title"] = "Маршруты: добавление и импорт";
}

<div class="page-header mb-4">
    <h1 class="display-5 fw-semibold">Маршруты: ручное добавление и импорт</h1>
    <p class="lead">Добавьте новый маршрут вручную или импортируйте несколько записей из Excel.</p>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Шаг 1. Ручное добавление или обновление маршрута</div>
    <div class="card-body">
        <form id="routeForm" class="row g-4" autocomplete="off">
            <div class="col-xl-5">
                <label class="form-label" for="routePartNameInput">Деталь</label>
                <input id="routePartNameInput" class="form-control form-control-lg" type="text" list="routePartOptions" placeholder="Наименование детали" autocomplete="off" />
                <datalist id="routePartOptions"></datalist>
                <div class="form-text">Введите новое имя или выберите существующее. Деталь сохраняется для всех операций ниже.</div>
            </div>
            <div class="col-12">
                <hr class="text-muted" />
                <h2 class="h5">Операции детали</h2>
                <p class="text-muted">Добавьте одну или несколько операций. После сохранения список очистится, а выбранная деталь останется, чтобы вы могли продолжить.</p>
            </div>
            <div class="col-xl-4">
                <label class="form-label" for="routeOperationNameInput">Операция</label>
                <input id="routeOperationNameInput" class="form-control form-control-lg" type="text" list="routeOperationOptions" placeholder="Наименование операции" autocomplete="off" />
                <datalist id="routeOperationOptions"></datalist>
                <div class="form-text">Введите название операции или выберите из списка.</div>
            </div>
            <div class="col-xl-2">
                <label class="form-label" for="routeOpNumberInput">№</label>
                <input id="routeOpNumberInput" class="form-control form-control-lg" type="text" inputmode="text" pattern="@OperationNumber.AllowedPattern" data-pattern="@OperationNumber.AllowedPattern" maxlength="16" />
                <div class="form-text">Допустимы 1–10 цифр, можно указать дробную часть через «/»</div>
            </div>
            <div class="col-xl-2">
                <label class="form-label" for="routeNormInput">Норматив (н/ч)</label>
                <input id="routeNormInput" class="form-control form-control-lg" type="number" min="0" step="0.001" />
                <div class="form-text">Три знака после запятой, больше нуля.</div>
            </div>
            <div class="col-xl-4">
                <label class="form-label" for="routeSectionNameInput">Вид работ</label>
                <input id="routeSectionNameInput" class="form-control form-control-lg" type="text" list="routeSectionOptions" placeholder="Наименование вида работ" autocomplete="off" />
                <datalist id="routeSectionOptions"></datalist>
                <div class="form-text">Укажите или выберите вид работ, на котором выполняется операция.</div>
            </div>
            <div class="col-12">
                <div class="d-flex flex-column flex-lg-row gap-3">
                    <button type="button" class="btn btn-secondary btn-lg" id="routeAddOperationButton">Добавить операцию в список (Enter)</button>
                    <button type="button" class="btn btn-primary btn-lg" id="routeSaveButton">Сохранить все операции (Ctrl+S)</button>
                    <button type="button" class="btn btn-secondary btn-lg" id="routeResetButton">Очистить форму (Esc)</button>
                </div>
            </div>
            <div class="col-12">
                <div class="table-responsive" id="routeOperationsContainer">
                    <table class="table table-striped align-middle mb-0">
                        <thead>
                            <tr>
                                <th scope="col">№</th>
                                <th scope="col">Операция</th>
                                <th scope="col">Норматив (н/ч)</th>
                                <th scope="col">Вид работ</th>
                                <th scope="col" class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody id="routeOperationsTableBody"></tbody>
                    </table>
                    <div id="routeOperationsEmptyState" class="text-muted py-3 text-center">Список операций пока пуст. Добавьте первую операцию, чтобы сохранить маршрут.</div>
                </div>
            </div>
        </form>
        <div id="routeSaveMessage" class="alert alert-success mt-4 d-none" role="status"></div>
    </div>
</div>

<div class="card shadow-sm mb-5">
    <div class="card-header bg-light fw-semibold">Шаг 2. Импорт маршрутов из Excel</div>
    <div class="card-body">
        <form id="routeImportForm" class="row g-3" enctype="multipart/form-data">
            <div class="col-lg-6">
                <label class="form-label" for="routeFileInput">Файл Excel</label>
                <input id="routeFileInput" class="form-control form-control-lg" type="file" accept=".xlsx,.xls" />
                <div class="form-text">Используйте Excel с колонками в таком порядке: Наименование детали, Код детали, № операции, Наименование операции, Вид работ, Норматив, н/ч. Колонка «Количество остатка» остаётся необязательной. При повторном импорте существующие строки обновляются, новые добавляются, удаление данных не выполняется.</div>
            </div>
            <div class="col-lg-6 d-flex align-items-end">
                <button type="button" class="btn btn-secondary btn-lg" id="routeImportButton">Импортировать файл</button>
            </div>
        </form>

        <div class="alert alert-secondary mt-4" role="note">
            <div class="fw-semibold mb-2">Пример таблицы для импорта</div>
            <div class="table-responsive">
                <table class="table table-sm table-bordered align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Наименование детали</th>
                            <th scope="col">Код детали</th>
                            <th scope="col">№ операции</th>
                            <th scope="col">Наименование операции</th>
                            <th scope="col">Вид работ</th>
                            <th scope="col">Норматив, н/ч</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Боковина</td>
                            <td>ТЭМ2.70.900.355</td>
                            <td>005</td>
                            <td>Заготовительная</td>
                            <td>Заготовительная</td>
                            <td>0,017</td>
                        </tr>
                        <tr>
                            <td>Боковина</td>
                            <td>ТЭМ2.70.900.355</td>
                            <td>010</td>
                            <td>Фрезерная</td>
                            <td>Фрезерная</td>
                            <td>0,1</td>
                        </tr>
                        <tr>
                            <td>Болт</td>
                            <td>СТ2К.01.005-01</td>
                            <td>010</td>
                            <td>Токарная</td>
                            <td>Токарная</td>
                            <td>0,333</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div id="routeImportSummary" class="mt-4"></div>
    </div>
</div>

<div class="card shadow-sm mb-5">
    <div class="card-header bg-light fw-semibold">Шаг 3. Импорт норм расхода материалов</div>
    <div class="card-body">
        <div class="alert alert-secondary" role="note">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                <div class="fw-semibold">Требуемый формат файла (готовый встроенный пример)</div>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-outline-primary btn-sm" asp-action="DownloadMetalImportTemplate">Скачать шаблон с примерами</a>
                    <a class="btn btn-outline-secondary btn-sm" asp-action="DownloadMetalImportEmptyTemplate">Скачать пустой шаблон</a>
                </div>
            </div>
            <ul class="mb-2">
                <li>Лист <code>Материалы и коэф. металлов</code>: используются колонки <strong>B–F</strong> (Артикул, Наименование, Вес, Коэф, Выбор).</li>
                <li>Лист <code>Детали - Размеры - Нормы</code>: используются колонки <strong>A–F</strong> (Обозначение, Наименование, Размеры мм, Текст нормы, Значение, Ед. изм.).</li>
                <li>Поддерживаемые единицы норм: <strong>м</strong>, <strong>м2</strong>, <strong>кг</strong>.</li>
            </ul>
            <div class="small text-muted">Рекомендуется начать с кнопки «Скачать шаблон с примерами», заполнить свои данные по образцу и затем импортировать файл.</div>
        </div>

        <form id="metalImportForm" class="row g-3" enctype="multipart/form-data">
            <div class="col-lg-7">
                <label class="form-label" for="metalFileInput">Файл "Нормы расхода материалов.xlsx"</label>
                <input id="metalFileInput" class="form-control form-control-lg" type="file" accept=".xlsx,.xls" />
            </div>
            <div class="col-lg-5">
                <label class="form-label" for="metalImportMode">Режим</label>
                <select id="metalImportMode" class="form-select form-select-lg">
                    <option value="all">Импорт всего файла</option>
                    <option value="materials">Импорт материалов</option>
                    <option value="norms">Импорт норм деталей</option>
                </select>
            </div>
            <div class="col-12 d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-outline-secondary" id="metalPreviewButton">Dry-run preview</button>
                <button type="button" class="btn btn-secondary" id="metalImportMaterialsButton">Импорт материалов</button>
                <button type="button" class="btn btn-secondary" id="metalImportNormsButton">Импорт норм деталей</button>
                <button type="button" class="btn btn-primary" id="metalImportAllButton">Импорт всего файла</button>
            </div>
        </form>

        <div id="metalImportSummary" class="mt-4"></div>
    </div>
</div>

@section Scripts
{
    <script src="~/js/routes-import.js" asp-append-version="true"></script>
}
